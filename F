# 11. Training Module
# =============================================================================

class Trainer:
    def __init__(self, cfg=None):
        self.cfg = cfg or RefinementConfig()
        self.engine = RefinementEngine(self.cfg)
        self.kernel = self.engine.kernel

    def train(self, pdb_list: List[str], epochs: int = 100, lr: float = 1e-3):
        structures = []
        for fpath in pdb_list:
            try:
                coords = self.engine._setup_openmm_from_pdb(fpath)
                structures.append(coords)
            except Exception as e:
                logger.warning(f"Skipping {fpath}: {e}")

        optimizer = torch.optim.Adam(self.kernel.parameters(), lr=lr)
        for epoch in range(epochs):
            total_loss = 0.0
            for coords_all in structures:
                coords_all = coords_all.clone().detach().requires_grad_(True)
                ca = self.engine._get_ca_coords(coords_all)
                M = ca.shape[0]
                alpha = torch.ones(M, device=coords_all.device)
                edge = self.engine.neighbor_mgr.build(ca)['soc']
                E_soc = self.engine.soc.compute_soc_energy(
                    ca, alpha, edge[0], edge[1], w_soc=self.cfg.w_soc)
                E_openmm = openmm_energy(coords_all, self.engine.system, self.engine.topology,
                                         self.cfg.openmm_platform)
                loss = E_openmm + E_soc
                optimizer.zero_grad()
                loss.backward()
                optimizer.step()
                total_loss += loss.item()
            if epoch % max(1, epochs // 10) == 0:
                print(f"Epoch {epoch:4d}  avg_loss={total_loss/len(structures):.4f}  "
                      f"α={self.kernel.alpha.item():.4f}  λ={self.kernel.lambd.item():.4f}")
        return self.kernel.alpha.item(), self.kernel.lambd.item()

