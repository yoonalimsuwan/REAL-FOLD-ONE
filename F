    orig_parser.add_argument('--shape', required=True)
    orig_parser.add_argument('--output', default='origami')
    orig_parser.add_argument('--bv_check', action='store_true')

    test_parser = sub.add_parser('test', help='Run gradient validation')
    test_parser.add_argument('--input', required=True)
    test_parser.add_argument('--platform', default='CUDA')

    args = parser.parse_args()

    if args.command == 'refine':
        cfg = RefinementConfig(
            device=args.device,
            steps=args.steps,
            lr=args.lr,
            use_rg=args.rg,
            use_langevin=args.langevin,
            solvate=args.solvate,
            ionic_strength=args.ionic_strength,
            box_padding=args.box_padding,
            openmm_platform=args.platform
        )
        engine = RefinementEngine(cfg)
        result = engine.refine(args.input, return_trajectory=args.trajectory)
        save_pdb(result['coords'], args.output, topology=engine.topology)
        print(f"Final energy: {result['final_energy']:.4f} kcal/mol")
        print(f"SOC sigma: {result['sigma']:.3f}  temperature: {result['temperature']:.1f} K")

    elif args.command == 'train':
        trainer = Trainer()
        alpha, lambd = trainer.train(args.input, epochs=args.epochs, lr=args.lr)
        print(f"Training finished. alpha={alpha:.4f}, lambda={lambd:.4f}")
        with open(args.output, 'w') as f:
            json.dump({'alpha': alpha, 'lambda': lambd}, f)

    elif args.command == 'origami':
        with open(args.shape) as f:
            data = json.load(f)
        origami = WireframeOrigami(data['vertices'], data['edges'])
        path = origami.route_scaffold()
        staples = origami.design_staples(path)
        print(f"Scaffold path length: {len(path)}")
        print(f"Designed {len(staples)} staples")
        origami.export_full_atom_pdb(f"{args.output}.pdb")
        origami.export_oxDNA(args.output)

    elif args.command == 'test':
        cfg = RefinementConfig(openmm_platform=args.platform)
        engine = RefinementEngine(cfg)
        error = validate_gradients(engine, args.input)
        print(f"Gradient validation error: {error:.6f}")
        if error < 0.01:
            print("Gradient test PASSED ✓")
        else:
            print("Gradient test FAILED ✗")

if __name__ == "__main__":
    main()
