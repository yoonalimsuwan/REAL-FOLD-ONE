def detect_optimal_device(verbose: bool = True) -> Tuple[torch.device, float]:
    device = torch.device("cpu")
    memory_gb = 4.0

    if torch.cuda.is_available():
        try:
            device_id = 0
            if "CUDA_VISIBLE_DEVICES" in os.environ:
                visible_devices = os.environ["CUDA_VISIBLE_DEVICES"]
                if visible_devices:
                    try:
                        device_id = int(visible_devices.split(",")[0])
                    except ValueError:
                        device_id = 0
            device = torch.device(f"cuda:{device_id}")
            device_name = torch.cuda.get_device_name(device_id)
            memory_gb = torch.cuda.get_device_properties(device_id).total_mem / 1e9
            if verbose:
                logger.info(f"✓ Using CUDA: {device_name} ({memory_gb:.1f} GB)")
            return device, memory_gb
        except Exception as e:
            if verbose:
                logger.warning(f"CUDA init failed: {e}")

    if hasattr(torch.backends, 'mps') and torch.backends.mps.is_available():
        try:
            device = torch.device("mps")
            try:
                import psutil
                memory_gb = psutil.virtual_memory().total / 1e9 * 0.7
            except ImportError:
                memory_gb = 8.0
            if verbose:
                logger.info(f"✓ Using Apple MPS (Metal) - ~{memory_gb:.1f} GB unified")
            return device, memory_gb
        except Exception as e:
            if verbose:
                logger.warning(f"MPS init failed: {e}")

    ascend_devices = os.environ.get("ASCEND_VISIBLE_DEVICES", "")
    if ascend_devices or os.path.exists("/usr/local/Ascend"):
        try:
            import torch_npu
            if torch_npu.npu.is_available():
                device = torch.device("npu:0")
                memory_gb = 16.0
                if verbose:
                    logger.info(f"✓ Using Huawei Ascend NPU - ~{memory_gb:.1f} GB")
                return device, memory_gb
        except ImportError:
            if verbose:
                logger.info("Huawei NPU driver not found")

    if hasattr(torch, 'xpu') and torch.xpu.is_available():
        try:
            device = torch.device("xpu:0")
            memory_gb = 8.0
            if verbose:
                logger.info(f"✓ Using Intel XPU - ~{memory_gb:.1f} GB")
            return device, memory_gb
        except Exception:
            pass

    try:
        import psutil
        memory_gb = psutil.virtual_memory().total / 1e9
    except ImportError:
        memory_gb = 4.0

    if verbose:
        logger.info(f"✓ Using CPU ({memory_gb:.1f} GB RAM)")
    return device, memory_gb

def get_chunk_size(available_memory_gb: float, n_atoms: int, dtype_bytes: int = 4) -> int:
    usable_memory = available_memory_gb * 0.5 * 1e9
    bytes_per_pair = dtype_bytes * 7
    max_pairs = max(int(usable_memory / bytes_per_pair), 100)
    chunk_size = min(int(math.sqrt(max_pairs)), 5000)
    return max(chunk_size, 50)

def memory_efficient_gather(tensor: torch.Tensor, indices: torch.Tensor) -> torch.Tensor:
    if tensor.numel() < 1000000:
        return tensor[indices]
    chunk_size = max(1, 1000000 // tensor.shape[-1])
    result = []
    for i in range(0, len(indices), chunk_size):
        chunk_indices = indices[i:i+chunk_size]
        result.append(tensor[chunk_indices])
    return torch.cat(result, dim=0)

