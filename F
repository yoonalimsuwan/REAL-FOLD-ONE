def compute_rmsd(coords1, coords2):
    if isinstance(coords1, np.ndarray):
        coords1 = torch.from_numpy(coords1)
    if isinstance(coords2, np.ndarray):
        coords2 = torch.from_numpy(coords2)
    c1 = coords1.float() - coords1.float().mean(dim=0)
    c2 = coords2.float() - coords2.float().mean(dim=0)
    C = c1.T @ c2
    U, S, Vt = torch.linalg.svd(C)
    V = Vt.T
    det = torch.det(V @ U.T)
    if det < 0:
        V[:, -1] = -V[:, -1]
    R = V @ U.T
    rotated = c2 @ R.T
    diff = c1 - rotated
    rmsd = torch.sqrt((diff**2).sum() / coords1.shape[0])
    return rmsd.item()

def validate_gradients(engine, pdb_file, eps=1e-4):
    coords = engine._setup_openmm_from_pdb(pdb_file).requires_grad_(True)
    E = openmm_energy(coords, engine.system, engine.topology, engine.cfg.openmm_platform)
    E.backward()
    anal_grad = coords.grad.clone()
    fd_grad = torch.zeros_like(coords)
    for i in range(min(10, coords.shape[0])):  # only first few atoms for speed
        for j in range(3):
            coords_plus = coords.clone().detach().requires_grad_(True)
            coords_minus = coords.clone().detach().requires_grad_(True)
            coords_plus[i, j] += eps
            coords_minus[i, j] -= eps
            Ep = openmm_energy(coords_plus, engine.system, engine.topology, engine.cfg.openmm_platform)
            Em = openmm_energy(coords_minus, engine.system, engine.topology, engine.cfg.openmm_platform)
            fd_grad[i, j] = (Ep - Em) / (2 * eps)
    diff = torch.norm(anal_grad[:10] - fd_grad[:10]) / (torch.norm(anal_grad[:10]) + 1e-8)
    return diff.item()

def save_pdb(coords, filename, topology=None):
    if topology is None:
        # Simple PDB writer
        with open(filename, 'w') as f:
            for i, (x, y, z) in enumerate(coords):
                f.write(f"ATOM  {i+1:5d}  X   UNK A{i+1:4d}    "
                        f"{x:8.3f}{y:8.3f}{z:8.3f}  1.00  0.00           X\n")
            f.write("END\n")
    else:
        # Use OpenMM's PDBFile.writeFile
        positions = [mm.Vec3(x, y, z) for x, y, z in coords * 0.1]  # to nm
        PDBFile.writeFile(topology, positions, open(filename, 'w'))
    print(f"PDB saved to {filename}")

