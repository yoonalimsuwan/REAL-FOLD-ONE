# 4. Differentiable OpenMM Energy Wrapper (PyTorch autograd)
# =============================================================================

class OpenMMEnergyFunction(torch.autograd.Function):
    """Compute potential energy and forces using OpenMM. Differentiable."""
    @staticmethod
    def forward(ctx, coords, system, topology, platform_name):
        # coords: (N,3) tensor in angstrom
        device = coords.device
        N = coords.shape[0]
        # Convert to OpenMM positions (nanometers)
        pos_np = coords.detach().cpu().numpy() * 0.1  # angstrom -> nm
        pos_mm = [mm.Vec3(x, y, z) for x, y, z in pos_np]

        # Create context
        platform = Platform.getPlatformByName(platform_name)
        integrator = VerletIntegrator(0.001)  # dummy, not used for dynamics
        context = Context(system, integrator, platform)
        context.setPositions(pos_mm)

        # Get energy
        state = context.getState(getEnergy=True, getForces=True)
        energy = state.getPotentialEnergy().value_in_unit(unit.kilojoule_per_mole)
        forces = state.getForces(asNumpy=True).value_in_unit(unit.kilojoule_per_mole / unit.nanometer)
        # forces in kJ/(mol·nm), convert to kcal/(mol·Å): 1 kJ/mol = 0.239006 kcal/mol, 1 nm = 10 Å, so multiply by 0.239006*0.1 = 0.0239006
        forces_kcal_per_ang = forces * 0.0239006
        energy_kcal = energy * 0.239006

        # Save for backward
        ctx.save_for_backward(torch.from_numpy(forces_kcal_per_ang).to(device))
        ctx.context = context

        return torch.tensor(energy_kcal, device=device, dtype=coords.dtype)

    @staticmethod
    def backward(ctx, grad_output):
        forces, = ctx.saved_tensors
        # dE/dx = -forces (since forces = -grad E)
        grad = -forces * grad_output
        # Clean up context
        del ctx.context
        return grad, None, None, None

def openmm_energy(coords: torch.Tensor, system: mm.System, topology: app.Topology,
                  platform: str = 'CUDA') -> torch.Tensor:
    """Compute energy using OpenMM, differentiable."""
    if coords.requires_grad:
        return OpenMMEnergyFunction.apply(coords, system, topology, platform)
    else:
        # Non-differentiable path
        with torch.no_grad():
            return OpenMMEnergyFunction.apply(coords, system, topology, platform)

