def place_atom_ic(a: torch.Tensor, b: torch.Tensor, c: torch.Tensor,
                  bond_len: float, angle_deg: float, dihedral_deg: float) -> torch.Tensor:
    bc = c - b
    bc_n = _normalize(bc)
    ab = a - b
    ab_perp = ab - torch.sum(ab * bc_n, dim=-1, keepdim=True) * bc_n
    ab_perp_n = _normalize(ab_perp)
    dih_rad = torch.deg2rad(dihedral_deg) if isinstance(dihedral_deg, torch.Tensor) else math.radians(dihedral_deg)
    cos_dih = torch.cos(dih_rad) if isinstance(dih_rad, torch.Tensor) else math.cos(dih_rad)
    sin_dih = torch.sin(dih_rad) if isinstance(dih_rad, torch.Tensor) else math.sin(dih_rad)
    rot_perp = cos_dih * ab_perp_n + sin_dih * torch.cross(bc_n, ab_perp_n, dim=-1)
    ang_rad = torch.deg2rad(torch.tensor(angle_deg)) if isinstance(angle_deg, (int, float)) else torch.deg2rad(angle_deg)
    cos_ang = torch.cos(ang_rad)
    sin_ang = torch.sin(ang_rad)
    bond_dir = cos_ang * bc_n + sin_ang * rot_perp
    return c + bond_len * bond_dir

