@dataclass
class RefinementConfig:
    w_soc: float = 0.3
    w_alpha_entropy: float = 0.5
    w_alpha_smooth: float = 0.1
    w_chain_break: float = 1.0
    cutoff_soc: float = 12.0
    max_neighbors: int = 64
    base_temp: float = 300.0
    friction: float = 0.02
    sigma_target: float = 1.0
    avalanche_threshold: float = 0.5
    w_avalanche: float = 0.2
    lr: float = 1e-4
    steps: int = 600
    rebuild_interval: int = 1
    use_amp: bool = True
    grad_clip: float = 5.0
    use_langevin: bool = False
    use_rg: bool = False
    rg_factor: int = 4
    rg_interval: int = 200
    use_ssc: bool = True
    epsilon_fp: float = 0.0028
    device: str = str(OPTIMAL_DEVICE)
    anneal_start: float = 1000.0
    anneal_end: float = 300.0
    anneal_cycles: int = 1
    openmm_platform: str = 'CUDA'
    solvate: bool = True
    ionic_strength: float = 0.15
    box_padding: float = 1.0

class RefinementEngine(nn.Module):
    def __init__(self, cfg: Optional[RefinementConfig] = None):
        super().__init__()
        self.cfg = cfg or RefinementConfig()
        self.device = torch.device(self.cfg.device)
        self.kernel = CSOCKernel(init_alpha=0.5, init_lambda=12.0)
        self.soc = SOCController(
            base_temp=self.cfg.base_temp,
            friction=self.cfg.friction,
            sigma_target=self.cfg.sigma_target,
            avalanche_threshold=self.cfg.avalanche_threshold,
            w_avalanche=self.cfg.w_avalanche,
            kernel=self.kernel,
            use_ssc=self.cfg.use_ssc,
            epsilon_fp=self.cfg.epsilon_fp,
            adaptive_friction=True
        )
        self.rg = DiffRGRefiner(self.cfg.rg_factor) if self.cfg.use_rg else None
        self.neighbor_mgr = NeighborListManager(
            cutoffs={'soc': self.cfg.cutoff_soc},
            max_neighbors=self.cfg.max_neighbors,
            device=self.device
        )
        self.scaler = GradScaler(enabled=self.cfg.use_amp and self.device.type == 'cuda')

        # OpenMM components (initialized during refine)
        self.system = None
        self.topology = None
        self.ca_atom_indices = None  # list of atom indices that are Cα or C4'
        self.n_total_atoms = 0

    def _setup_openmm_from_pdb(self, pdb_file: str):
        """Build OpenMM system and extract topology / CA indices."""
        builder = OpenMMSystemBuilder(
            solvent_model='tip3p',
            ionic_strength=self.cfg.ionic_strength,
            box_padding=self.cfg.box_padding,
            nonbonded_method='PME' if self.cfg.solvate else 'NoCutoff'
        )
        system, topology, pdb_obj = builder.build_from_pdb(
            pdb_file, solvate=self.cfg.solvate, add_ions=self.cfg.solvate
        )
        self.system = system
        self.topology = topology

        # Identify Cα atoms (protein) and C4' (DNA/RNA) for SOC on CA
        ca_indices = []
        for atom in topology.atoms():
            if atom.name in ('CA', 'C4\''):
                ca_indices.append(atom.index)
        self.ca_atom_indices = ca_indices
        self.n_total_atoms = topology.getNumAtoms()

        # Initial coordinates
        init_pos_nm = pdb_obj.getPositions(asNumpy=True)  # in nm
        init_coords_ang = torch.from_numpy(init_pos_nm) * 10.0  # to angstrom
        return init_coords_ang.to(self.device).float()

    def _get_ca_coords(self, full_coords: torch.Tensor) -> torch.Tensor:
        if self.ca_atom_indices is None or len(self.ca_atom_indices) == 0:
            return full_coords[0:0]
        return full_coords[self.ca_atom_indices]

    def _temperature_schedule(self, step, total_steps):
        if self.cfg.anneal_cycles <= 0:
            return self.cfg.base_temp
        cycle_len = total_steps // self.cfg.anneal_cycles
        if cycle_len == 0:
            return self.cfg.anneal_end
        cycle_step = step % cycle_len
        frac = cycle_step / cycle_len
        T = self.cfg.anneal_start + (self.cfg.anneal_end - self.cfg.anneal_start) * frac
        return max(T, self.cfg.anneal_end)

    def refine(self, pdb_file: str, steps: Optional[int] = None,
               chain_boundaries: Optional[List[int]] = None,
               ligand_files: Optional[List[str]] = None,
               return_trajectory: bool = False):
        if not HAS_OPENMM:
            raise ImportError("OpenMM is required for full-atom refinement.")
        if steps is None:
            steps = self.cfg.steps

        # Initialize OpenMM system and load initial coordinates
        coords_all = self._setup_openmm_from_pdb(pdb_file)
        coords_all.requires_grad_(True)
        N_atoms = coords_all.shape[0]

        # For SOC, we track per-residue alpha (one per CA) and Cα coordinates
        ca_coords = self._get_ca_coords(coords_all)  # [M, 3]
        M = ca_coords.shape[0]
        alpha = torch.ones(M, device=self.device, requires_grad=True)
        chi = None  # not used with full atom

        # Ligand bridge (if any) – future integration
        ligand_bridge = None

        # Reset SOC
        self.soc.reset_state()
        params = [coords_all, alpha]  # alpha is learnable per residue

        optimizer = torch.optim.Adam(params, lr=self.cfg.lr)
        energy_history = []
        best_energy = float('inf')
        best_coords = coords_all.clone().detach()
        best_alpha = alpha.clone().detach()
        trajectory = [] if return_trajectory else None

        # Build initial SOC edges (based on CA coordinates)
        edge_dict = self.neighbor_mgr.build(ca_coords)

        for step in range(steps):
            T_anneal = self._temperature_schedule(step, steps)
            self.soc.base_temp = T_anneal if self.cfg.anneal_cycles > 0 else self.cfg.base_temp

            optimizer.zero_grad()

            with autocast(enabled=self.cfg.use_amp and self.device.type == 'cuda'):
                # 1. OpenMM potential energy (differentiable)
                E_openmm = openmm_energy(coords_all, self.system, self.topology,
                                         platform=self.cfg.openmm_platform)

                # 2. SOC energy on CA coordinates
                ca_coords = self._get_ca_coords(coords_all)
                E_soc = self.soc.compute_soc_energy(
                    ca_coords, alpha,
                    edge_dict['soc'][0], edge_dict['soc'][1],
                    mask=None,
                    w_soc=self.cfg.w_soc
                )

                # 3. Alpha regularization
                ent = -(alpha * torch.log(alpha.clamp(min=1e-8))).sum()
                smooth = ((alpha[1:] - alpha[:-1]) ** 2).sum()
                E_alpha = self.cfg.w_alpha_entropy * ent + self.cfg.w_alpha_smooth * smooth

                # 4. Chain break penalty (if boundaries given)
                E_chain = torch.tensor(0.0, device=self.device)
                if chain_boundaries:
                    for b in chain_boundaries:
                        if 0 < b < M:
                            d = torch.norm(ca_coords[b] - ca_coords[b - 1])
                            E_chain += self.cfg.w_chain_break * torch.relu(d - 5.0)

                loss = E_openmm + E_soc + E_alpha + E_chain

            self.scaler.scale(loss).backward()

            # SOC avalanche gradient on CA coordinates
            av_grad = self.soc.avalanche_gradient(
                ca_coords, alpha, edge_dict['soc'][0], edge_dict['soc'][1]
            )
            if av_grad is not None:
                # Add avalanche gradient to corresponding full atom indices
                if coords_all.grad is not None and self.ca_atom_indices:
                    full_grad = coords_all.grad
                    idx = torch.tensor(self.ca_atom_indices, device=self.device, dtype=torch.long)
                    full_grad.index_add_(0, idx, av_grad)

            self.scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(params, self.cfg.grad_clip)
            self.scaler.step(optimizer)
            self.scaler.update()

            # Langevin noise (optional)
            sigma_val = self.soc.sigma(ca_coords.detach())
            T_val = self.soc.temperature(sigma_val)
            noise_scale = math.sqrt(2 * self.cfg.friction * T_val.item() / 300.0) * self.cfg.lr
            if self.cfg.use_langevin:
                noise = torch.randn_like(coords_all)
                coords_all.data.add_(noise * noise_scale)
            else:
                with torch.no_grad():
                    coords_all.add_(torch.randn_like(coords_all) * noise_scale)

            # RG coarse-graining on CA
            if self.rg is not None and step > 0 and step % self.cfg.rg_interval == 0:
                ca_smooth = self.rg(ca_coords.detach())
                displacement = ca_smooth - ca_coords.detach()
                # Move all atoms of each residue by the same displacement
                # (simple rigid-body move per residue)
                idx = torch.tensor(self.ca_atom_indices, device=self.device, dtype=torch.long)
                coords_all.data.index_add_(0, idx, displacement)

            # Rebuild edges periodically
            if step % self.cfg.rebuild_interval == 0:
                edge_dict = self.neighbor_mgr.build(self._get_ca_coords(coords_all.detach()))

            if loss.item() < best_energy:
                best_energy = loss.item()
                best_coords = coords_all.clone().detach()
                best_alpha = alpha.clone().detach()

            if step % 50 == 0:
                logger.info(f"step {step:04d}  E_total={loss.item():.4f}  σ={sigma_val.item():.3f}  T={T_val.item():.1f}")

            energy_history.append(loss.item())
            if return_trajectory:
                trajectory.append(best_coords.cpu().clone())

            if AVAILABLE_MEMORY_GB < 4.0 and step % 100 == 0:
                gc.collect()
                if self.device.type == 'cuda':
                    torch.cuda.empty_cache()

        self.soc.base_temp = self.cfg.base_temp
        return {
            'coords': best_coords.cpu().numpy(),
            'alpha': best_alpha.cpu().numpy(),
            'energy_history': energy_history,
            'final_energy': best_energy,
            'sigma': sigma_val.item(),
            'temperature': T_val.item(),
            'trajectory': torch.stack(trajectory).numpy() if return_trajectory and trajectory else None
        }

    def compute_energy(self, pdb_file: str) -> float:
        coords = self._setup_openmm_from_pdb(pdb_file).unsqueeze(0) if not isinstance(pdb_file, torch.Tensor) else pdb_file
        E = openmm_energy(coords, self.system, self.topology, self.cfg.openmm_platform)
        return E.item()

