class OpenMMSystemBuilder:
    """Builds an OpenMM System with explicit solvent and ions from a structure."""
    def __init__(self, forcefield_files: List[str] = None,
                 implicit_solvent: Optional[str] = None,
                 solvent_model: str = 'tip3p',
                 ionic_strength: float = 0.15,
                 box_padding: float = 1.0,
                 nonbonded_method: str = 'PME'):
        if not HAS_OPENMM:
            raise ImportError("OpenMM is required for full-atom refinement.")
        # Default force fields
        if forcefield_files is None:
            forcefield_files = [
                'amber14/protein.ff14SB.xml',
                'amber14/DNA.OL15.xml',
                'amber14/RNA.OL15.xml',
                'amber14/tip3p.xml'
            ]
        self.forcefield = ForceField(*forcefield_files)
        self.implicit_solvent = implicit_solvent
        self.solvent_model = solvent_model
        self.ionic_strength = ionic_strength
        self.box_padding = box_padding
        self.nonbonded_method = nonbonded_method

    def build_from_pdb(self, pdb_file: str, add_missing_residues: bool = True,
                       add_hydrogens: bool = True, solvate: bool = True,
                       add_ions: bool = True) -> Tuple[mm.System, app.Topology, List[app.PDBFile.PDBFile]]:
        """Returns OpenMM System, Topology, and list of PDBFile (for coordinates)."""
        pdb = PDBFile(pdb_file)
        modeller = Modeller(pdb.topology, pdb.positions)

        # Add missing residues and hydrogens
        if add_missing_residues:
            modeller.addMissingResidues()
        if add_hydrogens:
            modeller.addHydrogens(self.forcefield)

        # Solvate
        if solvate and self.implicit_solvent is None:
            modeller.addSolvent(self.forcefield,
                                model=self.solvent_model,
                                padding=self.box_padding * unit.nanometer,
                                ionicStrength=self.ionic_strength * unit.molar)
        elif self.implicit_solvent:
            # Implicit solvent (GB) – no solvent molecules
            pass

        # Add ions to neutralize
        if add_ions and solvate and self.implicit_solvent is None:
            modeller.addIons(self.forcefield, ionicStrength=self.ionic_strength * unit.molar)

        # Create system
        if self.implicit_solvent:
            system = self.forcefield.createSystem(
                modeller.topology,
                nonbondedMethod=NoCutoff,
                constraints=HBonds,
                implicitSolvent=self.implicit_solvent
            )
        else:
            if self.nonbonded_method == 'PME':
                nb = PME
            elif self.nonbonded_method == 'CutoffPeriodic':
                nb = CutoffPeriodic
            else:
                nb = CutoffNonPeriodic
            system = self.forcefield.createSystem(
                modeller.topology,
                nonbondedMethod=nb,
                nonbondedCutoff=1.0 * unit.nanometer,
                constraints=HBonds
            )

        return system, modeller.topology, pdb

