class CDRLoopModeler:
    def __init__(self, scorer: RosettaScorer, frag_db=None):
        self.scorer = scorer
        self.fragments = self._load_fragments(frag_db)

    def _load_fragments(self, path):
        if path and os.path.exists(path):
            with open(path) as f:
                return [tuple(x) for x in json.load(f)]
        return [(-65, -45), (-70, -40), (-60, -50), (-80, -30), (-55, -55),
                (-75, -35), (-62, -48), (-68, -42), (-58, -52), (-72, -38),
                (-90, -20), (-50, -60), (-85, -25), (-95, -15)]

    def remodel_loop(self, coords, seq, loop_start, loop_end, n_steps=500, temp=1.0):
        device = coords.device
        best_coords = coords.clone()
        current_coords = coords.clone()
        best_E = self.scorer.score_complex(
            current_coords[:loop_start], seq[:loop_start],
            current_coords[loop_end:], seq[loop_end:]
        ).item()
        for step in range(n_steps):
            if loop_end - loop_start < 2:
                continue
            pos = random.randint(loop_start, loop_end - 2)
            trial = current_coords.clone()
            trial[pos] += 0.5 * torch.randn(3, device=device)
            trial[pos + 1] += 0.5 * torch.randn(3, device=device)
            E_new = self.scorer.score_complex(
                trial[:loop_start], seq[:loop_start],
                trial[loop_end:], seq[loop_end:]
            ).item()
            delta = E_new - best_E
            if delta < 0 or random.random() < math.exp(-delta / temp):
                current_coords = trial
                if E_new < best_E:
                    best_E = E_new
                    best_coords = trial
        return best_coords

