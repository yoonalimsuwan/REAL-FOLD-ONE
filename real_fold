# 7. PME (Particle Mesh Ewald)
# =============================================================================
class PME:
    def __init__(self, grid_spacing=0.75, alpha=None):
        self.grid_spacing = grid_spacing
        self.alpha = alpha
        self.box = None
        self.inv_box = None
        self.ngrid = None

    def _setup_grid(self, coords):
        minc = coords.min(dim=0).values - 5.0
        maxc = coords.max(dim=0).values + 5.0
        L = (maxc - minc).max()
        minc = (minc + maxc)/2 - L/2
        maxc = minc + L
        box_vectors = torch.eye(3, device=coords.device) * L
        self.box = box_vectors
        self.inv_box = torch.inverse(box_vectors)
        self.ngrid = max(16, int(L / self.grid_spacing))
        return self.box, self.inv_box, self.ngrid

    def _spread(self, coords, q, inv_box, ngrid):
        frac = coords @ inv_box
        frac = frac - frac.floor()
        n = ngrid
        ix = (frac * n).long().clamp(0, n-1)
        wx = frac * n - ix.float()
        ix1 = (ix[:,0]+1) % n; iy1 = (ix[:,1]+1) % n; iz1 = (ix[:,2]+1) % n
        grid = torch.zeros((n,n,n), device=coords.device, dtype=coords.dtype)
        w000 = (1-wx[:,0])*(1-wx[:,1])*(1-wx[:,2])
        w100 = wx[:,0]*(1-wx[:,1])*(1-wx[:,2])
        w010 = (1-wx[:,0])*wx[:,1]*(1-wx[:,2])
        w001 = (1-wx[:,0])*(1-wx[:,1])*wx[:,2]
        w110 = wx[:,0]*wx[:,1]*(1-wx[:,2])
        w101 = wx[:,0]*(1-wx[:,1])*wx[:,2]
        w011 = (1-wx[:,0])*wx[:,1]*wx[:,2]
        w111 = wx[:,0]*wx[:,1]*wx[:,2]
        idx = (ix[:,0], ix[:,1], ix[:,2])
        idx100 = (ix1, ix[:,1], ix[:,2])
        idx010 = (ix[:,0], iy1, ix[:,2])
        idx001 = (ix[:,0], ix[:,1], iz1)
        idx110 = (ix1, iy1, ix[:,2])
        idx101 = (ix1, ix[:,1], iz1)
        idx011 = (ix[:,0], iy1, iz1)
        idx111 = (ix1, iy1, iz1)
        grid.index_put_(idx, q*w000, accumulate=True)
        grid.index_put_(idx100, q*w100, accumulate=True)
        grid.index_put_(idx010, q*w010, accumulate=True)
        grid.index_put_(idx001, q*w001, accumulate=True)
        grid.index_put_(idx110, q*w110, accumulate=True)
        grid.index_put_(idx101, q*w101, accumulate=True)
        grid.index_put_(idx011, q*w011, accumulate=True)
        grid.index_put_(idx111, q*w111, accumulate=True)
        return grid

    def _solve_recip(self, grid, box, ngrid, alpha):
        kx = torch.fft.fftfreq(ngrid, d=box[0,0]/ngrid).to(grid.device)
        ky = torch.fft.fftfreq(ngrid, d=box[1,1]/ngrid).to(grid.device)
        kz = torch.fft.fftfreq(ngrid, d=box[2,2]/ngrid).to(grid.device)
        KX, KY, KZ = torch.meshgrid(kx, ky, kz, indexing='ij')
        k2 = KX**2 + KY**2 + KZ**2
        k2[0,0,0] = 1.0
        B = torch.exp(-k2 / (4 * alpha**2)) / k2
        B[0,0,0] = 0.0
        Qk = torch.fft.fftn(grid)
        Ek = B * Qk.abs()**2
        E = 0.5 * Ek.sum().real * (box[0,0]*box[1,1]*box[2,2] / ngrid**3)
        return E

    def energy(self, coords, q):
        if coords.shape[0] == 0: return torch.tensor(0.0, device=coords.device)
        box, inv_box, ngrid = self._setup_grid(coords)
        if self.alpha is None:
            self.alpha = 0.4 / self.grid_spacing
        grid = self._spread(coords, q, inv_box, ngrid)
        E_recip = self._solve_recip(grid, box, ngrid, self.alpha)
        self_energy = -self.alpha / math.sqrt(math.pi) * (q**2).sum()
        return E_recip + self_energy

