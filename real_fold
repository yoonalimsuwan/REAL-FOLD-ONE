def compute_rmsd(coords1, coords2):
    if isinstance(coords1, np.ndarray):
        coords1 = torch.from_numpy(coords1)
    if isinstance(coords2, np.ndarray):
        coords2 = torch.from_numpy(coords2)
    c1 = coords1 - coords1.mean(dim=0)
    c2 = coords2 - coords2.mean(dim=0)
    C = c1.T @ c2
    U, S, Vt = torch.linalg.svd(C)
    V = Vt.T
    det = torch.det(V @ U.T)
    if det < 0:
        V[:, -1] = -V[:, -1]
    R = V @ U.T
    rotated = c2 @ R.T
    diff = c1 - rotated
    rmsd = torch.sqrt((diff**2).sum() / coords1.shape[0])
    return rmsd.item()

def validate_gradients(engine, coords, sequence, eps=1e-4):
    # Finite-difference gradient check
    device = coords.device
    L = len(sequence)
    coords0 = coords.detach().clone()
    # Analytical gradient
    coord_tmp = coords0.clone().detach().requires_grad_(True)
    edge_dict = engine._build_edges(coord_tmp)
    atoms = reconstruct_backbone(coord_tmp)
    edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, engine.cfg.max_neighbors).build(atoms['O'])['hb']
    alpha = torch.ones(L, device=device)
    chi = torch.zeros(L, MAX_CHI, device=device)
    chain_types = ['protein']*L
    mask = torch.ones(L, dtype=torch.bool, device=device)
    E = engine._total_energy(coord_tmp, sequence, alpha, chi,
                             edge_dict, edge_hb, edge_hb_dist,
                             [], chain_types, mask)
    E.backward()
    anal_grad = coord_tmp.grad.clone()
    # Numerical gradient
    fd_grad = torch.zeros_like(coords0)
    for i in range(L):
        for j in range(3):
            coord_plus = coords0.clone()
            coord_minus = coords0.clone()
            coord_plus[i,j] += eps
            coord_minus[i,j] -= eps
            E_plus = engine._total_energy(coord_plus, sequence, alpha, chi,
                                          engine._build_edges(coord_plus),
                                          *[NeighborListManager({'hb':3.5}, engine.cfg.max_neighbors).build(reconstruct_backbone(coord_plus)['O'])['hb']],
                                          [], chain_types, mask)
            E_minus = engine._total_energy(coord_minus, sequence, alpha, chi,
                                           engine._build_edges(coord_minus),
                                           *[NeighborListManager({'hb':3.5}, engine.cfg.max_neighbors).build(reconstruct_backbone(coord_minus)['O'])['hb']],
                                           [], chain_types, mask)
            fd_grad[i,j] = (E_plus - E_minus) / (2*eps)
    diff = torch.norm(anal_grad - fd_grad) / (torch.norm(anal_grad) + 1e-8)
    return diff.item()

