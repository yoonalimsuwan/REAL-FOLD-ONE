def place_atom_ic(a, b, c, bond_len, angle_deg, dihedral_deg):
    """Place atom D such that: D-C dist = bond_len, B-C-D angle = angle_deg,
    and A-B-C-D dihedral = dihedral_deg (in degrees). Coordinates a,b,c are tensors."""
    bc = c - b
    bc_n = bc / (torch.norm(bc) + 1e-8)
    ab = a - b
    # projection of AB perpendicular to BC
    ab_perp = ab - torch.dot(ab, bc_n) * bc_n
    ab_perp_n = ab_perp / (torch.norm(ab_perp) + 1e-8)
    cos_dih = math.cos(math.radians(dihedral_deg))
    sin_dih = math.sin(math.radians(dihedral_deg))
    # rotate ab_perp_n around bc_n by dihedral
    rot_perp = cos_dih * ab_perp_n + sin_dih * torch.cross(bc_n, ab_perp_n, dim=-1)
    cos_ang = math.cos(math.radians(angle_deg))
    sin_ang = math.sin(math.radians(angle_deg))
    bond_dir = cos_ang * bc_n + sin_ang * rot_perp
    return c + bond_len * bond_dir

