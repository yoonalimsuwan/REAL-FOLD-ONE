def build_single_nucleotide_ic(C4_prime, prev_C4, next_C4, nt_type):
    """Build full atom nucleotide given C4' coordinate and neighbours."""
    device = C4_prime.device
    top = NUCLEOTIDE_IC.get(nt_type, [])
    if not top:
        return torch.empty((0,3), device=device), []
    # Build local frame
    if prev_C4 is not None and next_C4 is not None:
        x = _normalize(next_C4 - C4_prime)
        vtmp = C4_prime - prev_C4
        z = _normalize(torch.cross(x, vtmp, dim=-1))
        y = torch.cross(z, x, dim=-1)
    elif next_C4 is not None:
        x = _normalize(next_C4 - C4_prime)
        z = torch.tensor([0.,0.,1.], device=device)
        y = torch.cross(z, x, dim=-1)
        if y.norm() < 1e-6:
            y = torch.tensor([0.,1.,0.], device=device)
            z = torch.cross(x, y, dim=-1)
        y = _normalize(y)
        z = _normalize(z)
    else:
        x = torch.tensor([1.,0.,0.], device=device)
        y = torch.tensor([0.,1.,0.], device=device)
        z = torch.tensor([0.,0.,1.], device=device)
    # Coordinates and types
    coords = [C4_prime]  # index 0 = C4'
    types = ['C4\'']
    for entry in top:
        name, atype, blen, ang, dih, ref = entry
        # ref[0] is the atom A, ref[1] = B, ref[2] = C
        # The list coords already has indices as they appear.
        if ref[0] >= len(coords) or ref[1] >= len(coords) or ref[2] >= len(coords):
            # safeguard, skip
            continue
        a = coords[ref[0]]
        b = coords[ref[1]]
        c = coords[ref[2]]
        new_pos = place_atom_ic(a, b, c, blen, ang, dih)
        coords.append(new_pos)
        types.append(atype)
    return torch.stack(coords), types

def build_full_dna_rna_corrected(C4_coords, sequence):
    """Build full atom DNA/RNA from C4' trace. Returns all_atom_coords, all_types, res_ids."""
    device = C4_coords.device
    L = len(sequence)
    all_coords = []
    all_types = []
    all_res = []
    for i in range(L):
        prev = C4_coords[i-1] if i > 0 else None
        nxt = C4_coords[i+1] if i < L-1 else None
        nc, nt = build_single_nucleotide_ic(C4_coords[i], prev, nxt, sequence[i])
        if nc.numel() == 0:
            continue
        all_coords.append(nc)
        all_types.extend(nt)
        all_res.append(torch.full((nc.shape[0],), i, dtype=torch.long, device=device))
    if not all_coords:
        return torch.empty((0,3), device=device), [], torch.empty(0, device=device, dtype=torch.long)
    return torch.cat(all_coords), all_types, torch.cat(all_res)

