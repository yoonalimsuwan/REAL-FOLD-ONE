@dataclass
class RefinementConfig:
    w_bond: float = 30.0; w_angle: float = 15.0; w_rama: float = 8.0; w_clash: float = 80.0
    w_hbond: float = 6.0; w_electro: float = 4.0; w_solvent: float = 5.0; w_soc: float = 0.3
    w_alpha_entropy: float = 0.5; w_alpha_smooth: float = 0.1; w_chain_break: float = 1.0
    w_lj: float = 30.0; w_coulomb: float = 5.0; w_torsion: float = 10.0
    cutoff: float = 12.0; max_neighbors: int = 64
    base_temp: float = 300.0; friction: float = 0.02; sigma_target: float = 1.0
    avalanche_threshold: float = 0.5; w_avalanche: float = 0.2
    lr: float = 1e-4; steps: int = 600; rebuild_interval: int = 1
    use_amp: bool = True; grad_clip: float = 5.0; use_milstein: bool = False
    use_rg: bool = False; rg_factor: int = 4; rg_interval: int = 200
    use_ssc: bool = True; epsilon_fp: float = 0.0028
    use_pme: bool = True; pme_grid_spacing: float = 0.75
    device: str = "cuda" if torch.cuda.is_available() else "cpu"
    anneal_start: float = 1000.0; anneal_end: float = 300.0; anneal_cycles: int = 1

class RefinementEngine:
    def __init__(self, cfg: Optional[RefinementConfig] = None):
        self.cfg = cfg or RefinementConfig()
        self.device = torch.device(self.cfg.device)
        self.kernel = CSOCKernel(init_alpha=0.5, init_lambda=12.0)
        self.soc = SOCController(
            base_temp=self.cfg.base_temp, friction=self.cfg.friction,
            sigma_target=self.cfg.sigma_target, avalanche_threshold=self.cfg.avalanche_threshold,
            w_avalanche=self.cfg.w_avalanche, kernel=self.kernel,
            use_ssc=self.cfg.use_ssc, epsilon_fp=self.cfg.epsilon_fp,
            adaptive_friction=True
        )
        self.rg = DiffRGRefiner(self.cfg.rg_factor) if self.cfg.use_rg else None
        self.scaler = GradScaler(enabled=self.cfg.use_amp and self.device.type == 'cuda')
        self.pme = PME(grid_spacing=self.cfg.pme_grid_spacing) if self.cfg.use_pme else None
        self.neighbor_mgr = NeighborListManager(
            cutoffs={'clash':2.5, 'lj':6.0, 'elec':self.cfg.cutoff},
            max_neighbors=self.cfg.max_neighbors,
            device=self.device
        )

    def _build_edges(self, coords, batch=None):
        return self.neighbor_mgr.build(coords, batch)

    def _temperature_schedule(self, step, total_steps):
        if self.cfg.anneal_cycles <= 0:
            return self.cfg.base_temp
        cycle_len = total_steps // self.cfg.anneal_cycles
        cycle_step = step % cycle_len
        frac = cycle_step / cycle_len
        T = self.cfg.anneal_start + (self.cfg.anneal_end - self.cfg.anneal_start) * frac
        return max(T, self.cfg.anneal_end)

    def _total_energy(self, ca, seq, alpha, chi,
                      edge_dict, edge_hb, edge_hb_dist,
                      boundaries, chain_types, mask,
                      ligand_bridge=None):
        """Unified full-atom energy."""
        device = ca.device
        E = torch.tensor(0.0, device=device)
        prot_mask = torch.tensor([t == 'protein' for t in chain_types], device=device, dtype=torch.bool)
        dna_mask  = torch.tensor([t in ('dna','rna') for t in chain_types], device=device, dtype=torch.bool)
        if mask is not None:
            prot_mask = prot_mask & mask
            dna_mask  = dna_mask & mask

        # --- Coarse-grained terms (backbone) ---
        if prot_mask.any():
            E += energy_bond(ca, alpha, self.cfg.w_bond, mod=0.1, target=3.8, mask=prot_mask)
            E += energy_angle(ca, alpha, self.cfg.w_angle, mod=0.05, target_rad=111.0*math.pi/180.0, mask=prot_mask)
            atoms = reconstruct_backbone(ca)
            phi, psi = compute_phi_psi(atoms)
            E += energy_rama(phi, psi, seq, alpha, self.cfg.w_rama, mod=0.2, mask=prot_mask)
            E += energy_clash(ca, alpha, edge_dict['clash'][0], edge_dict['clash'][1],
                              self.cfg.w_clash, radius=2.0, mod=0.1, mask=prot_mask)
            E += energy_hbond(atoms['O'], atoms['N'], atoms['C'], alpha,
                              edge_hb, edge_hb_dist, self.cfg.w_hbond, mod=0.1, mask=prot_mask)
            E += energy_solvent(ca, seq, edge_dict['elec'][0], self.cfg.w_solvent, mask=prot_mask)
            E += self.soc.compute_soc_energy(ca, alpha, edge_dict['elec'][0], edge_dict['elec'][1],
                                             mask=prot_mask, w_soc=self.cfg.w_soc)
            E += alpha_regularisation(alpha, self.cfg.w_alpha_entropy, self.cfg.w_alpha_smooth)

        if dna_mask.any():
            # Use coarse DNA terms on C4' trace
            dna_idx = torch.where(dna_mask)[0]
            if len(dna_idx) > 0:
                dna_ca = ca[dna_idx]
                dna_seq = "".join(seq[i] for i in dna_idx.tolist())
                for i in range(len(dna_seq)):
                    for j in range(i+4, min(len(dna_seq), i+50)):
                        d = torch.norm(dna_ca[i]-dna_ca[j])
                        n = WC_PAIRS.get((dna_seq[i], dna_seq[j]), 0)
                        if n > 0:
                            E += -n * 8.0 * torch.exp(-((d-10.5)/2.0)**2)
                    if i < len(dna_seq)-1:
                        d = torch.norm(dna_ca[i+1]-dna_ca[i])
                        s = 0.5*(BASE_STACKING.get(dna_seq[i],1.0)+BASE_STACKING.get(dna_seq[i+1],1.0))
                        E += -s * 5.0 * torch.exp(-((d-6.5)/1.5)**2)

        # --- Full‑atom nonbonded (LJ + Coulomb) ---
        # Gather all full atoms from protein, DNA, and ligands
        all_coords = []
        all_types = []
        all_charges = []
        # Protein full atoms
        if prot_mask.any():
            prot_idx = torch.where(prot_mask)[0]
            prot_ca = ca[prot_idx]
            prot_seq = "".join(seq[i] for i in prot_idx.tolist())
            prot_chi = chi[prot_idx] if chi is not None else None
            prot_coords, prot_types, prot_res = build_protein_full_atoms(prot_ca, prot_seq, prot_chi)
            if prot_coords.shape[0] > 0:
                all_coords.append(prot_coords)
                all_types.extend(prot_types)
                all_charges.extend([AMBER_CHARGES.get(t,0.0) for t in prot_types])
        # DNA full atoms
        if dna_mask.any():
            dna_idx = torch.where(dna_mask)[0]
            dna_ca = ca[dna_idx]  # CA trace holds C4' for DNA
            dna_seq = "".join(seq[i] for i in dna_idx.tolist())
            dna_coords, dna_types, dna_res = build_full_dna_rna_corrected(dna_ca, dna_seq)
            if dna_coords.shape[0] > 0:
                all_coords.append(dna_coords)
                all_types.extend(dna_types)
                all_charges.extend([DNA_RNA_CHARGES.get(t,0.0) for t in dna_types])
        # Ligand atoms
        if ligand_bridge is not None:
            for lig in ligand_bridge.ligands:
                if lig.atom_coords is not None:
                    all_coords.append(lig.atom_coords)
                    for i in range(lig.n_atoms):
                        all_types.append(lig.atom_gaff_types[i] if i<len(lig.atom_gaff_types) else 'c3')
                        all_charges.append(lig.atom_charges[i].item() if lig.atom_charges is not None else 0.0)

        if all_coords:
            all_c = torch.cat(all_coords, dim=0)
            all_q = torch.tensor(all_charges, device=device)
            all_t = all_types
            # Build neighbor list for full atoms
            nb_edge, nb_dist = self.neighbor_mgr.build(all_c)['lj']
            # Nonbonded energy
            if nb_edge.numel() > 0:
                src, dst = nb_edge
                # get LJ params
                sig = torch.zeros(len(all_t), device=device)
                eps = torch.zeros(len(all_t), device=device)
                for i,t in enumerate(all_t):
                    s, e = AMBER_LJ.get(t, DNA_RNA_LJ.get(t, GAFF2_LJ.get(t, (1.9,0.1))))
                    sig[i] = s; eps[i] = e
                sig_ij = 0.5*(sig[src]+sig[dst])
                eps_ij = torch.sqrt(eps[src]*eps[dst])
                r = torch.clamp(nb_dist, min=1e-4)
                inv_r = 1.0/r
                lj = 4.0*eps_ij * ((sig_ij*inv_r)**12 - (sig_ij*inv_r)**6)
                E += self.cfg.w_lj * lj.sum()
                # Coulomb short-range
                qi, qj = all_q[src], all_q[dst]
                coul = COULOMB_CONST * qi * qj / (4.0 * r)
                # Exclude 1-2,1-3 bonds? Not implemented for simplicity; use PME for long-range.
                if self.pme is None:
                    E += self.cfg.w_coulomb * coul.sum()
                # PME long-range on full atoms
                if self.pme is not None:
                    E += self.pme.energy(all_c, all_q)
                # Protein bonded terms (bond, angle, torsion) at full-atom level
                # We can add them here, but they are partially captured by backbone terms.
                # For full accuracy, implement protein bonded energy on full atoms.
                # (omitted for brevity but the framework is here)
        # Chain break
        E += chain_break_energy(ca, boundaries, self.cfg.w_chain_break)
        # Ligand internal energy
        if ligand_bridge is not None:
            E += ligand_bridge.compute_ligand_energy()
        return E

    def refine(self, coords, sequence, mask=None, chain_types=None, chain_boundaries=None,
               ligand_files=None, steps=None, logger=None, return_trajectory=False) -> Dict:
        if steps is None: steps = self.cfg.steps
        if isinstance(coords, np.ndarray):
            coords = torch.tensor(coords, dtype=torch.float32, device=self.device)
        else:
            coords = coords.to(self.device).float()
        L = len(sequence)
        if mask is None: mask = torch.ones(L, dtype=torch.bool, device=self.device)
        else: mask = torch.tensor(mask, dtype=torch.bool, device=self.device)
        if chain_types is None:
            chain_types = [detect_sequence_type(sequence[i:i+1]) for i in range(L)]
        if chain_boundaries is None: chain_boundaries = []
        chi = torch.zeros(L, MAX_CHI, device=self.device, requires_grad=True)
        alpha = torch.ones(L, device=self.device, requires_grad=True)
        # Ligands
        ligand_bridge = None
        ligand_params = []
        if ligand_files:
            ligand_bridge = LigandBridge()
            for f in ligand_files:
                ext = os.path.splitext(f)[1].lower().lstrip('.')
                ftype = 'sdf' if ext in ('sdf','') else 'mol2' if ext=='mol2' else 'pdb' if ext=='pdb' else 'sdf'
                ligand_bridge.load_ligand_file(f, ftype)
            for lig in ligand_bridge.ligands:
                lig.to_device(self.device)
                lig.atom_coords = lig.atom_coords.detach().requires_grad_(True)
                ligand_params.append(lig.atom_coords)
        # Initial edges
        edge_dict = self._build_edges(coords)
        atoms = reconstruct_backbone(coords)
        edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, self.cfg.max_neighbors).build(atoms['O'])['hb']
        params = [coords, chi, alpha] + ligand_params
        optimizer = torch.optim.Adam(params, lr=self.cfg.lr)
        energy_history = []
        best_energy = float('inf')
        best_coords = coords.clone()
        best_chi = chi.clone()
        best_alpha = alpha.clone()
        trajectory = [] if return_trajectory else None
        for step in range(steps):
            T_anneal = self._temperature_schedule(step, steps)
            self.soc.base_temp = T_anneal if self.cfg.anneal_cycles > 0 else self.cfg.base_temp
            optimizer.zero_grad()
            with autocast(enabled=self.cfg.use_amp and self.device.type == 'cuda'):
                E = self._total_energy(coords, sequence, alpha, chi,
                                       edge_dict, edge_hb, edge_hb_dist,
                                       chain_boundaries, chain_types, mask,
                                       ligand_bridge)
                loss = E
            self.scaler.scale(loss).backward()
            av_grad = self.soc.avalanche_gradient(coords, alpha, edge_dict['elec'][0], edge_dict['elec'][1])
            if av_grad is not None and coords.grad is not None:
                coords.grad = coords.grad + av_grad
            self.scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(params, self.cfg.grad_clip)
            self.scaler.step(optimizer)
            self.scaler.update()
            sigma = self.soc.sigma(coords.detach())
            T = self.soc.temperature(sigma)
            noise_scale = math.sqrt(2 * self.cfg.friction * T.item() / 300.0) * self.cfg.lr
            if self.cfg.use_milstein:
                noise = torch.randn_like(coords)
                coords.data.add_(noise * noise_scale)
                chi.data.add_(torch.randn_like(chi) * noise_scale * 0.5)
                for lc in ligand_params:
                    lc.data.add_(torch.randn_like(lc) * noise_scale * 0.1)
            else:
                with torch.no_grad():
                    coords.add_(torch.randn_like(coords) * noise_scale)
                    chi.data.add_(torch.randn_like(chi) * noise_scale * 0.5)
                    for lc in ligand_params:
                        lc.add_(torch.randn_like(lc) * noise_scale * 0.1)
            if self.rg and step > 0 and step % self.cfg.rg_interval == 0:
                coords.data = self.rg.forward(coords.data)
            if step % self.cfg.rebuild_interval == 0:
                edge_dict = self._build_edges(coords.detach())
                atoms = reconstruct_backbone(coords.detach())
                edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, self.cfg.max_neighbors).build(atoms['O'])['hb']
            if loss.item() < best_energy:
                best_energy = loss.item()
                best_coords = coords.clone().detach()
                best_chi = chi.clone().detach()
                best_alpha = alpha.clone().detach()
            if logger and step % 50 == 0:
                logger.info(f"step {step:04d}  E={loss.item():.4f}  σ={sigma.item():.3f}  T={T.item():.1f}")
            energy_history.append(loss.item())
            if return_trajectory:
                trajectory.append(best_coords.cpu().clone())
        self.soc.base_temp = self.cfg.base_temp
        return {
            'coords': best_coords.cpu().numpy(),
            'chi': best_chi.cpu().numpy(),
            'alpha': best_alpha.cpu().numpy(),
            'energy_history': energy_history,
            'final_energy': best_energy,
            'sigma': sigma.item(),
            'temperature': T.item(),
            'trajectory': np.stack(trajectory) if return_trajectory else None
        }

    def compute_energy(self, coords, sequence, chain_types=None, mask=None, chi=None, alpha=None) -> float:
        if coords.dim() == 2: coords = coords.unsqueeze(0)
        coords = coords.view(-1, 3)
        L = len(sequence)
        if mask is None: mask = torch.ones(L, dtype=torch.bool, device=coords.device)
        if chain_types is None: chain_types = [detect_sequence_type(sequence[i:i+1]) for i in range(L)]
        if chi is None: chi = torch.zeros(L, 4, device=coords.device)
        if alpha is None: alpha = torch.ones(L, device=coords.device)
        edge_dict = self._build_edges(coords)
        atoms = reconstruct_backbone(coords)
        edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, self.cfg.max_neighbors).build(atoms['O'])['hb']
        E = self._total_energy(coords, sequence, alpha, chi,
                               edge_dict, edge_hb, edge_hb_dist,
                               [], chain_types, mask)
        return E.item()

    def relax_local(self, coords, sequence, positions, steps=30, window=3,
                    chain_types=None, mask=None, chi=None, alpha=None):
        if coords.dim() == 2: coords = coords.unsqueeze(0)
        coords = coords.view(-1, 3).detach().requires_grad_(True)
        L = len(sequence)
        if mask is None: mask = torch.ones(L, dtype=torch.bool, device=coords.device)
        if chain_types is None: chain_types = [detect_sequence_type(sequence[i:i+1]) for i in range(L)]
        if chi is None: chi = torch.zeros(L, 4, device=coords.device)
        if alpha is None: alpha = torch.ones(L, device=coords.device)
        min_pos = min(positions); max_pos = max(positions)
        win_start = max(0, min_pos - window); win_end = min(L, max_pos + window + 1)
        opt = torch.optim.Adam([coords], lr=self.cfg.lr)
        best_E = float('inf'); best_coords = coords.clone()
        edge_dict = self._build_edges(coords)
        atoms = reconstruct_backbone(coords)
        edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, self.cfg.max_neighbors).build(atoms['O'])['hb']
        for step in range(steps):
            opt.zero_grad()
            E = self._total_energy(coords, sequence, alpha, chi,
                                   edge_dict, edge_hb, edge_hb_dist,
                                   [], chain_types, mask)
            E.backward()
            if coords.grad is not None:
                grad_mask = torch.zeros(L, 3, device=coords.device)
                grad_mask[win_start:win_end] = 1.0
                coords.grad *= grad_mask
            opt.step()
            edge_dict = self._build_edges(coords.detach())
            atoms = reconstruct_backbone(coords.detach())
            edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, self.cfg.max_neighbors).build(atoms['O'])['hb']
            if E.item() < best_E:
                best_E = E.item()
                best_coords = coords.clone().detach()
        return best_coords.detach(), best_E

# =============================================================================
# 16. Training Module
# =============================================================================
class Trainer:
    def __init__(self, cfg: RefinementConfig = None):
        self.cfg = cfg or RefinementConfig()
        self.engine = RefinementEngine(self.cfg)
        self.kernel = self.engine.kernel

    def load_structures(self, file_list):
        data = []
        for fpath in file_list:
            if not HAS_BIOTITE:
                raise ImportError("biotite required for training")
            struct = load_structure(fpath)
            data.append((struct['coords'], struct['sequence']))
        return data

    def train(self, file_list, epochs=100, lr=1e-3, use_full_atom=True, verbose=True):
        structures = self.load_structures(file_list)
        optimizer = torch.optim.Adam(self.kernel.parameters(), lr=lr)
        for epoch in range(epochs):
            total_loss = 0.0
            for coords_np, seq in structures:
                coords = torch.tensor(coords_np, dtype=torch.float32, device=self.engine.device)
                L = len(seq)
                alpha = torch.ones(L, device=self.engine.device)
                chi = torch.zeros(L, MAX_CHI, device=self.engine.device)
                chain_types = [detect_sequence_type(c) for c in seq]
                mask = torch.ones(L, dtype=torch.bool, device=self.engine.device)
                edge_dict = self.engine._build_edges(coords)
                atoms = reconstruct_backbone(coords)
                edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, self.engine.cfg.max_neighbors).build(atoms['O'])['hb']
                E = self.engine._total_energy(
                    coords, seq, alpha, chi,
                    edge_dict, edge_hb, edge_hb_dist,
                    [], chain_types, mask)
                loss = E
                optimizer.zero_grad()
                loss.backward()
                optimizer.step()
                total_loss += loss.item()
            if verbose and epoch % max(1, epochs//10) == 0:
                print(f"Epoch {epoch:4d}  avg_loss={total_loss/len(structures):.4f}  "
                      f"α={self.kernel.alpha.item():.4f}  λ={self.kernel.lambd.item():.4f}")
        return self.kernel.alpha.item(), self.kernel.lambd.item()

# =============================================================================
# 17. I/O Utilities
# =============================================================================
def load_structure(filepath, chain=None):
    if not HAS_BIOTITE:
        raise ImportError("biotite required for structure I/O")
    if filepath.endswith('.pdb'):
        struct = pdb_io.PDBFile.read(filepath).get_structure(model=1)
    elif filepath.endswith('.cif') or filepath.endswith('.mmcif'):
        struct = mmcif_io.MMCIFFile.read(filepath).get_structure(model=1)
    else:
        raise ValueError("File must be .pdb or .cif/.mmcif")
    if chain is not None:
        struct = struct[struct.chain_id == chain]
    ca = struct[struct.atom_name == "CA"]
    coords = ca.coord.astype(np.float32)
    seq = [AA_3_TO_1.get(res.res_name, 'X') for res in ca.residues]
    return {'coords': coords, 'sequence': "".join(seq), 'chain_ids': list(ca.chain_id)}

def save_structure(coords, sequence, filename, chain_id='A'):
    with open(filename, 'w') as f:
        for i, (x,y,z) in enumerate(coords):
            aa = sequence[i] if i < len(sequence) else 'X'
            f.write(f"ATOM  {i+1:5d}  CA  {aa:3s} {chain_id}{i+1:4d}    "
                    f"{x:8.3f}{y:8.3f}{z:8.3f}  1.00  0.00           C\n")
        f.write("END\n")
    print(f"Saved CA‑only PDB to {filename}")

