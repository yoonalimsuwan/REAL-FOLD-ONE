# 11. Energy Functions (All Terms, Fully Differentiable)
# =============================================================================
# (reconstruct_backbone already moved above)

def dihedral_angle(p0: torch.Tensor, p1: torch.Tensor, p2: torch.Tensor,
                   p3: torch.Tensor) -> torch.Tensor:
    b0 = p1 - p0
    b1 = p2 - p1
    b2 = p3 - p2
    b1n = _normalize(b1)
    v = b0 - (b0 * b1n).sum(-1, keepdim=True) * b1n
    w = b2 - (b2 * b1n).sum(-1, keepdim=True) * b1n
    x = (v * w).sum(-1)
    y = torch.cross(b1n, v, dim=-1)
    y = (y * w).sum(-1)
    return torch.atan2(y + 1e-8, x + 1e-8)

def compute_phi_psi(atoms: Dict[str, torch.Tensor]) -> Tuple[torch.Tensor, torch.Tensor]:
    N, CA, C = atoms['N'], atoms['CA'], atoms['C']
    L = CA.shape[0]
    phi = torch.zeros(L, device=CA.device)
    psi = torch.zeros(L, device=CA.device)
    if L > 2:
        phi[1:-1] = dihedral_angle(C[:-2], N[1:-1], CA[1:-1], C[1:-1])
        psi[1:-1] = dihedral_angle(N[1:-1], CA[1:-1], C[1:-1], N[2:])
    return phi * 180.0 / math.pi, psi * 180.0 / math.pi

def energy_bond(ca: torch.Tensor, alpha: torch.Tensor, w: float = 30.0,
                mod: float = 0.1, target: float = 3.8,
                mask: Optional[torch.Tensor] = None) -> torch.Tensor:
    if mask is not None and not mask.any():
        return torch.tensor(0.0, device=ca.device)
    alpha_clamped = alpha.clamp(min=0.1)
    t = target * (1.0 + mod * (alpha_clamped - 1.0))
    t_pair = 0.5 * (t[1:] + t[:-1])
    d = torch.norm(ca[1:] - ca[:-1], dim=-1)
    if mask is not None:
        bm = mask[1:] & mask[:-1]
        if bm.sum() == 0:
            return torch.tensor(0.0, device=ca.device)
        return w * ((d[bm] - t_pair[bm])**2).sum()
    return w * ((d - t_pair)**2).sum()

def energy_angle(ca: torch.Tensor, alpha: torch.Tensor, w: float = 15.0,
                 mod: float = 0.05, target_rad: float = 111.0 * math.pi / 180.0,
                 mask: Optional[torch.Tensor] = None) -> torch.Tensor:
    if len(ca) < 3:
        return torch.tensor(0.0, device=ca.device)
    v1 = ca[:-2] - ca[1:-1]
    v2 = ca[2:] - ca[1:-1]
    v1n = _normalize(v1)
    v2n = _normalize(v2)
    cos_a = (v1n * v2n).sum(-1)
    alpha_clamped = alpha.clamp(min=0.1)
    t = target_rad * (1.0 + mod * (alpha_clamped[1:-1] - 1.0))
    cos_t = torch.cos(t)
    if mask is not None:
        am = mask[1:-1]
        if am.sum() == 0:
            return torch.tensor(0.0, device=ca.device)
        return w * ((cos_a[am] - cos_t[am])**2).sum()
    return w * ((cos_a - cos_t)**2).sum()

def energy_rama(phi: torch.Tensor, psi: torch.Tensor, seq: str,
                alpha: torch.Tensor, w: float = 8.0, mod: float = 0.2,
                mask: Optional[torch.Tensor] = None) -> torch.Tensor:
    L = len(seq)
    device = phi.device
    p0 = torch.zeros(L, device=device)
    p1 = torch.zeros(L, device=device)
    wd = torch.zeros(L, device=device)
    for i, aa in enumerate(seq):
        pr = RAMACHANDRAN_PRIORS.get(aa, RAMACHANDRAN_PRIORS['general'])
        p0[i] = pr['phi']
        p1[i] = pr['psi']
        wd[i] = pr['width']
    alpha_clamped = alpha.clamp(min=0.1)
    weff = wd * (1.0 + mod * (alpha_clamped - 1.0))
    dphi = (phi - p0) / (weff + 1e-8)
    dpsi = (psi - p1) / (weff + 1e-8)
    loss = dphi**2 + dpsi**2
    if mask is None:
        mask = torch.ones(L, device=device, dtype=torch.bool)
    mask = mask.clone()
    mask[0] = False
    mask[-1] = False
    if mask.sum() == 0:
        return torch.tensor(0.0, device=device)
    return w * (loss * mask.float()).sum()

def energy_clash(ca: torch.Tensor, alpha: torch.Tensor,
                 edge_idx: torch.Tensor, edge_dist: torch.Tensor,
                 w: float = 80.0, radius: float = 2.0, mod: float = 0.1,
                 mask: Optional[torch.Tensor] = None) -> torch.Tensor:
    if edge_idx.numel() == 0:
        return torch.tensor(0.0, device=ca.device)
    i, j = edge_idx[0], edge_idx[1]
    keep = (torch.abs(i - j) > 2)
    if not keep.any():
        return torch.tensor(0.0, device=ca.device)
    i, j = i[keep], j[keep]
    d = edge_dist[keep]
    if mask is not None:
        keep2 = mask[i] & mask[j]
        if not keep2.any():
            return torch.tensor(0.0, device=ca.device)
        i, j = i[keep2], j[keep2]
        d = d[keep2]
    alpha_clamped = alpha.clamp(min=0.1)
    ri = radius * (1.0 + mod * (alpha_clamped[i] - 1.0))
    rj = radius * (1.0 + mod * (alpha_clamped[j] - 1.0))
    rad = 0.5 * (ri + rj)
    clash = torch.relu(rad - d)
    if clash.numel() == 0:
        return torch.tensor(0.0, device=ca.device)
    return w * (clash**2).sum()

def energy_electro(ca: torch.Tensor, seq: str, edge_idx: torch.Tensor,
                   edge_dist: torch.Tensor, w: float = 4.0,
                   mask: Optional[torch.Tensor] = None) -> torch.Tensor:
    if edge_idx.numel() == 0:
        return torch.tensor(0.0, device=ca.device)
    q = torch.tensor([RESIDUE_CHARGE.get(a, 0.0) for a in seq], device=ca.device)
    qi, qj = q[edge_idx[0]], q[edge_idx[1]]
    if mask is not None:
        keep = mask[edge_idx[0]] & mask[edge_idx[1]]
        if not keep.any():
            return torch.tensor(0.0, device=ca.device)
        qi, qj = qi[keep], qj[keep]
        r = torch.clamp(edge_dist[keep], min=1e-6)
    else:
        r = torch.clamp(edge_dist, min=1e-6)
    E = qi * qj * torch.exp(-0.1 * r) / (80.0 * r)
    return w * E.sum()

def energy_solvent(ca: torch.Tensor, seq: str, edge_idx: torch.Tensor,
                   w: float = 5.0, mask: Optional[torch.Tensor] = None) -> torch.Tensor:
    if edge_idx.numel() == 0:
        return torch.tensor(0.0, device=ca.device)
    src = edge_idx[0]
    cnt = torch.zeros(ca.shape[0], device=ca.device)
    cnt.index_add_(0, src, torch.ones_like(src, dtype=torch.float))
    if mask is not None:
        cnt = cnt * mask.float()
    burial = 1.0 - torch.exp(-cnt / 20.0)
    hydro = torch.tensor([HYDROPHOBICITY.get(a, 0.0) for a in seq], device=ca.device)
    exposed = torch.where(hydro > 0, hydro * (1.0 - burial), torch.zeros_like(burial))
    buried = torch.where(hydro <= 0, -hydro * burial, torch.zeros_like(burial))
    return w * (exposed + buried).sum()

def energy_hbond(O: torch.Tensor, N: torch.Tensor, C: torch.Tensor,
                 alpha: torch.Tensor, edge_idx: torch.Tensor,
                 edge_dist: torch.Tensor, w: float = 6.0, mod: float = 0.1,
                 mask: Optional[torch.Tensor] = None) -> torch.Tensor:
    if edge_idx.numel() == 0:
        return torch.tensor(0.0, device=O.device)
    src, dst = edge_idx[0], edge_idx[1]
    if mask is not None:
        keep = mask[src] & mask[dst]
        if not keep.any():
            return torch.tensor(0.0, device=O.device)
        src, dst = src[keep], dst[keep]
        d = edge_dist[keep]
    else:
        d = edge_dist
    vec_co = O[src] - C[src]
    vec_no = N[dst] - O[src]
    align = F.cosine_similarity(vec_co, vec_no, dim=-1, eps=1e-8)
    alpha_clamped = alpha.clamp(min=0.1)
    ideal = 2.9 * (1.0 + mod * (alpha_clamped[src] - 1.0))
    E = -align * torch.exp(-((d - ideal) / 0.3)**2)
    return w * E.sum()

def alpha_regularisation(alpha: torch.Tensor, w_ent: float = 0.5,
                         w_smooth: float = 0.1) -> torch.Tensor:
    ent = -(alpha * torch.log(alpha.clamp(min=1e-8))).sum()
    sm = ((alpha[1:] - alpha[:-1])**2).sum()
    return w_ent * ent + w_smooth * sm

def chain_break_energy(ca: torch.Tensor, boundaries: List[int],
                       w: float = 1.0) -> torch.Tensor:
    if not boundaries:
        return torch.tensor(0.0, device=ca.device)
    E = torch.tensor(0.0, device=ca.device)
    for b in boundaries:
        if 0 < b < len(ca):
            d = torch.norm(ca[b] - ca[b - 1], dim=-1)
            E = E + w * torch.relu(d - 5.0)
    return E

