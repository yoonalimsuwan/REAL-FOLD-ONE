class ProtonationFixer:
    """Add hydrogens, detect disulfide bonds, adjust protonation states."""
    def __init__(self, ph=7.0):
        self.ph = ph
        # AMBER hydrogen addition rules (simplified)
        self.ideal_bond_lengths = {
            ('N','H'):1.01, ('CA','HA'):1.09, ('CB','HB'):1.09,
            ('C','O'):1.23, ('O','H'):0.96, ('SG','HG'):1.34,
        }

    def fix(self, full_coords, full_types, sequence, res_idx):
        """Add missing hydrogens and adjust HIS protonation."""
        device = full_coords.device
        new_coords = [full_coords]
        new_types = list(full_types)
        new_res_idx = res_idx.clone()
        current_len = len(full_coords)
        # Simple hydrogen addition for backbone and sidechains
        for i, (aa, idx) in enumerate(zip(sequence, res_idx)):
            # Backbone H on N for non-proline
            if aa != 'P':
                # Find N atom
                n_mask = (res_idx == i) & (torch.tensor(full_types, device=device) == 'N')
                if n_mask.any():
                    n_pos = full_coords[n_mask][0]
                    ca_mask = (res_idx == i) & (torch.tensor(full_types, device=device) == 'CA')
                    if ca_mask.any():
                        ca_pos = full_coords[ca_mask][0]
                        c_mask = (res_idx == i) & (torch.tensor(full_types, device=device) == 'C')
                        if c_mask.any():
                            c_pos = full_coords[c_mask][0]
                            # Place H opposite to C direction
                            v = n_pos - ca_pos
                            w = n_pos - c_pos
                            h_dir = _normalize(v + w)  # roughly opposite
                            h_pos = n_pos + 1.01 * h_dir
                            new_coords.append(h_pos.unsqueeze(0))
                            new_types.append('H')
                            new_res_idx = torch.cat([new_res_idx, torch.tensor([i], device=device)])
        # Detect disulfide bonds
        disulf_pairs = []
        cys_indices = [j for j,aa in enumerate(sequence) if aa == 'C']
        for a in range(len(cys_indices)):
            i = cys_indices[a]
            sg_i_mask = (res_idx == i) & (torch.tensor(full_types, device=device) == 'SG')
            if not sg_i_mask.any(): continue
            pos_i = full_coords[sg_i_mask][0]
            for b in range(a+1, len(cys_indices)):
                j = cys_indices[b]
                sg_j_mask = (res_idx == j) & (torch.tensor(full_types, device=device) == 'SG')
                if not sg_j_mask.any(): continue
                pos_j = full_coords[sg_j_mask][0]
                dist = torch.norm(pos_i - pos_j).item()
                if dist < 2.5:
                    disulf_pairs.append((i, j))
        # Adjust HIS protonation based on pH (simplified: neutral at pH 7)
        # For now, just keep as-is; could rename HIE/HID/HIP
        return torch.cat(new_coords, dim=0), new_types, new_res_idx, disulf_pairs

