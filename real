def build_full_dna_rna_corrected(C4_coords: torch.Tensor, sequence: str) -> Tuple[torch.Tensor, List[str], torch.Tensor]:
    device = C4_coords.device
    L = len(sequence)
    all_coords = []
    all_types = []
    all_res = []
    for i in range(L):
        prev = C4_coords[i-1] if i > 0 else None
        nxt = C4_coords[i+1] if i < L-1 else None
        top = NUCLEOTIDE_IC.get(sequence[i], [])
        if not top:
            continue
        C4_prime = C4_coords[i]
        # Build local frame
        if prev is not None and nxt is not None:
            x = _normalize(nxt - C4_prime)
            vtmp = C4_prime - prev
            z = _normalize(torch.cross(x, vtmp, dim=-1))
            y = torch.cross(z, x, dim=-1)
        elif nxt is not None:
            x = _normalize(nxt - C4_prime)
            z = torch.tensor([0., 0., 1.], device=device)
            y = torch.cross(z, x, dim=-1)
            if torch.norm(y) < 1e-6:
                y = torch.tensor([0., 1., 0.], device=device)
                z = torch.cross(x, y, dim=-1)
            y = _normalize(y)
            z = _normalize(z)
        else:
            x = torch.tensor([1., 0., 0.], device=device)
            y = torch.tensor([0., 1., 0.], device=device)
            z = torch.tensor([0., 0., 1.], device=device)
        # Virtual atoms to define first bond direction
        vx = C4_prime + x * 1.0
        vy = C4_prime + y * 1.0
        # coords: 0 = C4', 1 = vx, 2 = vy
        coords = [C4_prime, vx, vy]
        types_list = ['C4\'', 'VX', 'VY']  # virtual atoms won't be kept
        for entry in top:
            name, atype, blen, ang, dih, ref = entry
            # adjust indices: original first entry (0,0,1) -> (0,1,2), others add 2
            if ref == (0, 0, 1):
                adj_ref = (0, 1, 2)
            else:
                adj_ref = tuple(r + 2 for r in ref)
            if any(r >= len(coords) for r in adj_ref):
                continue
            a = coords[adj_ref[0]]
            b = coords[adj_ref[1]]
            c = coords[adj_ref[2]]
            new_pos = place_atom_ic(a, b, c, blen, ang, dih)
            coords.append(new_pos)
            types_list.append(atype)
        # Discard virtual atoms (indices 1 and 2)
        real_coords = coords[3:]
        real_types = types_list[3:]
        nc = torch.stack(real_coords)
        all_coords.append(nc)
        all_types.extend(real_types)
        all_res.append(torch.full((nc.shape[0],), i, dtype=torch.long, device=device))
    if not all_coords:
        return (torch.empty((0, 3), device=device),
                [],
                torch.empty(0, device=device, dtype=torch.long))
    return torch.cat(all_coords), all_types, torch.cat(all_res)

