def compute_rmsd(coords1: Union[np.ndarray, torch.Tensor],
                 coords2: Union[np.ndarray, torch.Tensor]) -> float:
    if isinstance(coords1, np.ndarray):
        coords1 = torch.from_numpy(coords1)
    if isinstance(coords2, np.ndarray):
        coords2 = torch.from_numpy(coords2)
    c1 = coords1.float() - coords1.float().mean(dim=0)
    c2 = coords2.float() - coords2.float().mean(dim=0)
    C = c1.T @ c2
    U, S, Vt = torch.linalg.svd(C)
    V = Vt.T
    det = torch.det(V @ U.T)
    if det < 0:
        V[:, -1] = -V[:, -1]
    R = V @ U.T
    rotated = c2 @ R.T
    diff = c1 - rotated
    rmsd = torch.sqrt((diff**2).sum() / coords1.shape[0])
    return rmsd.item()

def validate_gradients(engine: RefinementEngine, coords: torch.Tensor,
                       sequence: str, eps: float = 1e-4) -> float:
    device = coords.device
    L = len(sequence)
    coords0 = coords.detach().clone()
    coord_tmp = coords0.clone().detach().requires_grad_(True)
    edge_dict = engine._build_edges(coord_tmp)
    atoms = reconstruct_backbone(coord_tmp)
    edge_hb, edge_hb_dist = NeighborListManager(
        {'hb': 3.5}, engine.cfg.max_neighbors, device
    ).build(atoms['O'])['hb']
    alpha = torch.ones(L, device=device)
    chi = torch.zeros(L, MAX_CHI, device=device)
    chain_types = ['protein'] * L
    mask = torch.ones(L, dtype=torch.bool, device=device)
    E = engine._total_energy(
        coord_tmp, sequence, alpha, chi,
        edge_dict, edge_hb, edge_hb_dist,
        [], chain_types, mask
    )
    E.backward()
    anal_grad = coord_tmp.grad.clone()
    fd_grad = torch.zeros_like(coords0)
    for i in range(L):
        for j in range(3):
            coord_plus = coords0.clone()
            coord_minus = coords0.clone()
            coord_plus[i, j] += eps
            coord_minus[i, j] -= eps
            ed_plus = engine._build_edges(coord_plus)
            atoms_plus = reconstruct_backbone(coord_plus)
            ehb_plus, ehd_plus = NeighborListManager(
                {'hb': 3.5}, engine.cfg.max_neighbors, device
            ).build(atoms_plus['O'])['hb']
            E_plus = engine._total_energy(
                coord_plus, sequence, alpha, chi,
                ed_plus, ehb_plus, ehd_plus,
                [], chain_types, mask
            )
            ed_minus = engine._build_edges(coord_minus)
            atoms_minus = reconstruct_backbone(coord_minus)
            ehb_minus, ehd_minus = NeighborListManager(
                {'hb': 3.5}, engine.cfg.max_neighbors, device
            ).build(atoms_minus['O'])['hb']
            E_minus = engine._total_energy(
                coord_minus, sequence, alpha, chi,
                ed_minus, ehb_minus, ehd_minus,
                [], chain_types, mask
            )
            fd_grad[i, j] = (E_plus - E_minus) / (2 * eps)
    diff = torch.norm(anal_grad - fd_grad) / (torch.norm(anal_grad) + 1e-8)
    return diff.item()

def save_full_atom_pdb(coords: torch.Tensor, sequence: str,
                       filename: str, chi: Optional[torch.Tensor] = None):
    if chi is None:
        chi = torch.zeros(len(sequence), MAX_CHI)
    full_c, full_t, full_r = build_protein_full_atoms(coords, sequence, chi)
    with open(filename, 'w') as f:
        atom_idx = 1
        for i in range(len(full_c)):
            x, y, z = full_c[i].tolist()
            atype = full_t[i]
            res_id = full_r[i].item()
            aa = sequence[res_id] if res_id < len(sequence) else 'X'
            f.write(f"ATOM  {atom_idx:5d}  {atype:<3s} {aa:3s} A{res_id+1:4d}    "
                    f"{x:8.3f}{y:8.3f}{z:8.3f}  1.00  0.00           {atype[0]}\n")
            atom_idx += 1
        f.write("END\n")
    print(f"Full‑atom PDB saved to {filename}")

def load_structure(filepath: str, chain: Optional[str] = None) -> Dict[str, Any]:
    if not HAS_BIOTITE:
        raise ImportError("biotite required for structure I/O")
    if filepath.endswith('.pdb'):
        struct = pdb_io.PDBFile.read(filepath).get_structure(model=1)
    elif filepath.endswith('.cif') or filepath.endswith('.mmcif'):
        struct = mmcif_io.MMCIFFile.read(filepath).get_structure(model=1)
    else:
        raise ValueError("File must be .pdb or .cif/.mmcif")
    if chain is not None:
        struct = struct[struct.chain_id == chain]
    ca = struct[struct.atom_name == "CA"]
    coords = ca.coord.astype(np.float32)
    seq = [AA_3_TO_1.get(res.res_name, 'X') for res in ca.residues]
    return {
        'coords': coords,
        'sequence': "".join(seq),
        'chain_ids': list(ca.chain_id)
    }

def save_structure(coords: np.ndarray, sequence: str, filename: str,
                   chain_id: str = 'A'):
    with open(filename, 'w') as f:
        for i, (x, y, z) in enumerate(coords):
            aa = sequence[i] if i < len(sequence) else 'X'
            f.write(f"ATOM  {i+1:5d}  CA  {aa:3s} {chain_id}{i+1:4d}    "
                    f"{x:8.3f}{y:8.3f}{z:8.3f}  1.00  0.00           C\n")
        f.write("END\n")
    print(f"Saved CA‑only PDB to {filename}")

# =============================================================================
# 20. Command Line Interface
# =============================================================================

def main():
    parser = argparse.ArgumentParser(
        description="REAL FOLD ONE – Universal Full-Atom SOC Refinement Engine"
    )
    sub = parser.add_subparsers(dest='command', required=True)

    refine_parser = sub.add_parser('refine', help='Refine a protein/DNA structure')
    refine_parser.add_argument('--input', '-i', required=True)
    refine_parser.add_argument('--chain', default=None)
    refine_parser.add_argument('--output', '-o', default='refined.pdb')
    refine_parser.add_argument('--steps', type=int, default=600)
    refine_parser.add_argument('--lr', type=float, default=1e-4)
    refine_parser.add_argument('--ligand', nargs='+')
    refine_parser.add_argument('--boundaries', nargs='+', type=int)
    refine_parser.add_argument('--device', default=str(OPTIMAL_DEVICE))
    refine_parser.add_argument('--rg', action='store_true')
    refine_parser.add_argument('--no_ssc', action='store_true')
    refine_parser.add_argument('--trajectory', action='store_true')
    refine_parser.add_argument('--milstein', action='store_true')
    refine_parser.add_argument('--pme', action='store_true', default=True)
    refine_parser.add_argument('--full_atom', action='store_true',
                               help='Export full‑atom PDB')

    train_parser = sub.add_parser('train', help='Train SOC kernel on native structures')
    train_parser.add_argument('--input', nargs='+', required=True)
    train_parser.add_argument('--epochs', type=int, default=100)
    train_parser.add_argument('--lr', type=float, default=1e-3)
    train_parser.add_argument('--full_atom', action='store_true')
    train_parser.add_argument('--output', default='kernel_params.json')

    ab_parser = sub.add_parser('antibody', help='Antibody CDR loop modelling')
    ab_parser.add_argument('--antigen', required=True)
    ab_parser.add_argument('--cdr_start', type=int, default=95)
    ab_parser.add_argument('--cdr_end', type=int, default=102)
    ab_parser.add_argument('--output', default='antibody.pdb')

    orig_parser = sub.add_parser('origami', help='DNA origami design')
    orig_parser.add_argument('--shape', required=True)
    orig_parser.add_argument('--output', default='origami')
    orig_parser.add_argument('--bv_check', action='store_true')

    test_parser = sub.add_parser('test', help='Run gradient validation test')
    test_parser.add_argument('--full', action='store_true')

    args = parser.parse_args()

    if args.command == 'refine':
        if not HAS_BIOTITE:
            print("Install biotite: pip install biotite")
            sys.exit(1)
        data = load_structure(args.input, args.chain)
        coords, seq = data['coords'], data['sequence']
        print(f"Loaded {len(seq)} residues")
        cfg = RefinementConfig(
            device=args.device,
            steps=args.steps,
            lr=args.lr,
            use_rg=args.rg,
            use_ssc=not args.no_ssc,
            use_milstein=args.milstein,
            use_pme=args.pme
        )
        engine = RefinementEngine(cfg)
        logging.basicConfig(level=logging.INFO)
        log = logging.getLogger("REAL_FOLD_ONE")
        result = engine.refine(
            coords, seq,
            ligand_files=args.ligand,
            chain_boundaries=args.boundaries,
            logger=log,
            return_trajectory=args.trajectory
        )
        if args.full_atom and args.output:
            full_coords = torch.tensor(result['coords'])
            chi = torch.tensor(result['chi'])
            save_full_atom_pdb(full_coords, seq, args.output, chi)
        else:
            save_structure(result['coords'], seq, args.output)
        print(f"Final energy: {result['final_energy']:.4f} kcal/mol")
        print(f"SOC sigma: {result['sigma']:.3f}  temperature: {result['temperature']:.1f} K")
        if args.trajectory and result['trajectory'] is not None:
            np.save(args.output.replace('.pdb', '_traj.npy'), result['trajectory'])

    elif args.command == 'train':
        trainer = Trainer()
        alpha, lambd = trainer.train(
            args.input, epochs=args.epochs, lr=args.lr,
            use_full_atom=args.full_atom
        )
        print(f"Training finished. alpha={alpha:.4f}, lambda={lambd:.4f}")
        if args.output:
            with open(args.output, 'w') as f:
                json.dump({'alpha': alpha, 'lambda': lambd}, f)
            print(f"Parameters saved to {args.output}")

    elif args.command == 'antibody':
        if not HAS_BIOTITE:
            print("biotite required")
            sys.exit(1)
        ant = load_structure(args.antigen)
        ant_coords = torch.tensor(ant['coords'], dtype=torch.float32)
        ant_seq = ant['sequence']
        print(f"Antigen: {len(ant_seq)} residues")
        ab_coords = torch.randn(len(ant_seq), 3) * 10
        ab_seq = "A" * len(ant_seq)
        scorer = RosettaScorer()
        modeler = CDRLoopModeler(scorer)
        best = modeler.remodel_loop(
            ab_coords, ab_seq, args.cdr_start, args.cdr_end,
            n_steps=500, temp=1.0
        )
        save_structure(best.cpu().numpy(), ab_seq, args.output)
        print(f"Antibody saved to {args.output}")

    elif args.command == 'origami':
        with open(args.shape) as f:
            data = json.load(f)
        vertices = data['vertices']
        edges = data['edges']
        origami = WireframeOrigami(vertices, edges)
        path = origami.route_scaffold()
        staples = origami.design_staples(path)
        print(f"Scaffold path length: {len(path)}")
        print(f"Designed {len(staples)} staples")
        if args.bv_check:
            cycles = []
            if HAS_NX:
                g = nx.Graph()
                g.add_nodes_from(range(len(vertices)))
                g.add_edges_from(edges)
                cycles = nx.cycle_basis(g)
            if cycles:
                print(f"Found {len(cycles)} cycles - topology valid")
            else:
                print("No cycles found or networkx not available")
        origami.export_full_atom_pdb(f"{args.output}.pdb")
        origami.export_oxDNA(args.output)

    elif args.command == 'test':
        seq = "AA"
        coords = torch.tensor([[0.0, 0.0, 0.0], [3.8, 0.0, 0.0]], dtype=torch.float32)
        cfg = RefinementConfig(
            steps=20, device='cpu', use_rg=False, use_amp=False
        )
        engine = RefinementEngine(cfg)
        result = engine.refine(coords, seq, steps=20)
        print(f"Final energy: {result['final_energy']:.4f}")
        rmsd = compute_rmsd(coords, torch.tensor(result['coords']))
        print(f"RMSD from initial: {rmsd:.4f} Å")
        if args.full:
            diff = validate_gradients(engine, coords, seq)
            print(f"Gradient validation error: {diff:.6f}")
            if diff < 0.01:
                print("Gradient test PASSED ✓")
            else:
                print("Gradient test FAILED ✗")
        else:
            print("Skipping gradient test (use --full to enable)")

if __name__ == "__main__":
    main()
