class LigandEnergy:
    def __init__(self, w_bond: float = 300.0, w_angle: float = 50.0,
                 w_torsion: float = 1.0, w_improper: float = 10.0,
                 w_lj: float = 30.0, w_coulomb: float = 3.0,
                 lj_params: Optional[Dict] = None, dielectric: float = 4.0):
        self.w_bond = w_bond
        self.w_angle = w_angle
        self.w_torsion = w_torsion
        self.w_improper = w_improper
        self.w_lj = w_lj
        self.w_coulomb = w_coulomb
        self.lj_params = lj_params or GAFF2_LJ
        self.diel = dielectric

    def __call__(self, mol: Molecule) -> torch.Tensor:
        E = torch.tensor(0.0, device=mol.atom_coords.device)
        E += self._bond(mol)
        E += self._angle(mol)
        E += self._torsion(mol)
        E += self._improper(mol)
        E += self._nonbonded(mol)
        return E

    def _bond(self, mol: Molecule) -> torch.Tensor:
        E = torch.tensor(0.0, device=mol.atom_coords.device)
        for (i, j), o in zip(mol.bonds, mol.bond_orders):
            d = torch.norm(mol.atom_coords[j] - mol.atom_coords[i])
            r0 = 1.50
            E += self.w_bond * 300.0 * (d - r0)**2
        return E

    def _angle(self, mol: Molecule) -> torch.Tensor:
        E = torch.tensor(0.0, device=mol.atom_coords.device)
        for i, j, k in mol.angles:
            v1 = mol.atom_coords[i] - mol.atom_coords[j]
            v2 = mol.atom_coords[k] - mol.atom_coords[j]
            cos_val = torch.clamp(torch.dot(v1, v2) / (torch.norm(v1) * torch.norm(v2) + 1e-8), -1, 1)
            theta = torch.acos(cos_val)
            E += self.w_angle * 50.0 * (theta - math.radians(109.5))**2
        return E

    def _torsion(self, mol: Molecule) -> torch.Tensor:
        E = torch.tensor(0.0, device=mol.atom_coords.device)
        for (i, j, k, l), per in zip(mol.torsions, mol.torsion_periodicities):
            phi = self._dihedral(mol.atom_coords[i], mol.atom_coords[j],
                                 mol.atom_coords[k], mol.atom_coords[l])
            V = 1.0
            delta = math.pi if per == 2 else 0.0
            E += self.w_torsion * 1.0 * V * (1 + torch.cos(per * phi - delta))
        return E

    def _improper(self, mol: Molecule) -> torch.Tensor:
        E = torch.tensor(0.0, device=mol.atom_coords.device)
        for i, j, k, l in mol.impropers:
            phi = self._dihedral(mol.atom_coords[i], mol.atom_coords[j],
                                 mol.atom_coords[k], mol.atom_coords[l])
            E += self.w_improper * 10.0 * phi**2
        return E

    def _nonbonded(self, mol: Molecule) -> torch.Tensor:
        E = torch.tensor(0.0, device=mol.atom_coords.device)
        n = mol.n_atoms
        excl = self._excl(mol)
        is14 = self._14list(mol)
        for i in range(n):
            for j in range(i + 1, n):
                if (i, j) in excl or (j, i) in excl:
                    continue
                d = torch.norm(mol.atom_coords[i] - mol.atom_coords[j]) + 1e-8
                sc_coul = 0.833 if ((i, j) in is14 or (j, i) in is14) else 1.0
                sc_lj = 0.5 if ((i, j) in is14 or (j, i) in is14) else 1.0
                gi = mol.atom_gaff_types[i] if i < len(mol.atom_gaff_types) else 'c3'
                gj = mol.atom_gaff_types[j] if j < len(mol.atom_gaff_types) else 'c3'
                si, ei = self.lj_params.get(gi, (1.9, 0.1))
                sj, ej = self.lj_params.get(gj, (1.9, 0.1))
                sig = 0.5 * (si + sj)
                eps = math.sqrt(ei * ej)
                inv_r = 1.0 / d
                lj = 4.0 * eps * ((sig * inv_r)**12 - (sig * inv_r)**6)
                E += self.w_lj * sc_lj * lj
                if mol.atom_charges is not None:
                    qi, qj = mol.atom_charges[i], mol.atom_charges[j]
                    coul = COULOMB_CONST * qi * qj / (self.diel * d)
                    E += self.w_coulomb * sc_coul * coul
        return E

    def _excl(self, mol: Molecule) -> set:
        excl = set()
        for i, j in mol.bonds:
            excl.add((i, j))
            excl.add((j, i))
        adj = defaultdict(set)
        for i, j in mol.bonds:
            adj[i].add(j)
            adj[j].add(i)
        for i in range(mol.n_atoms):
            for j in adj[i]:
                for k in adj[j]:
                    if k != i:
                        excl.add((i, k))
        return excl

    def _14list(self, mol: Molecule) -> set:
        p14 = set()
        adj = defaultdict(set)
        for i, j in mol.bonds:
            adj[i].add(j)
            adj[j].add(i)
        for i in range(mol.n_atoms):
            for j in adj[i]:
                for k in adj[j]:
                    if k == i:
                        continue
                    for l in adj[k]:
                        if l != i and l != j:
                            p14.add((i, l))
        return p14

    def _dihedral(self, p0: torch.Tensor, p1: torch.Tensor,
                  p2: torch.Tensor, p3: torch.Tensor) -> torch.Tensor:
        b0 = p1 - p0
        b1 = p2 - p1
        b2 = p3 - p2
        b1n = _normalize(b1)
        v = b0 - (b0 * b1n).sum(-1, keepdim=True) * b1n
        w = b2 - (b2 * b1n).sum(-1, keepdim=True) * b1n
        x = (v * w).sum(-1)
        y = torch.cross(b1n, v, dim=-1)
        y = (y * w).sum(-1)
        return torch.atan2(y + 1e-8, x + 1e-8)

class ProteinLigandEnergy:
    def __init__(self, w_lj: float = 30.0, w_coulomb: float = 3.0,
                 prot_lj: Optional[Dict] = None, lig_lj: Optional[Dict] = None,
                 prot_charges: Optional[Dict] = None, dielectric: float = 4.0,
                 cutoff: float = 12.0):
        self.w_lj = w_lj
        self.w_coulomb = w_coulomb
        self.prot_lj = prot_lj or AMBER_LJ
        self.lig_lj = lig_lj or GAFF2_LJ
        self.prot_charges = prot_charges or AMBER_CHARGES
        self.diel = dielectric
        self.cut = cutoff

    def __call__(self, prot_coords: torch.Tensor, prot_types: List[str],
                 prot_qlist: List[float], ligand: Molecule) -> torch.Tensor:
        device = prot_coords.device
        E = torch.tensor(0.0, device=device)
        lig_coords = ligand.atom_coords.to(device)
        lig_q = ligand.atom_charges
        for i in range(len(prot_coords)):
            ppos = prot_coords[i]
            ptype = prot_types[i] if i < len(prot_types) else 'CA'
            pq = prot_qlist[i] if i < len(prot_qlist) else 0.0
            for j in range(ligand.n_atoms):
                d = torch.norm(ppos - lig_coords[j]) + 1e-8
                if d > self.cut:
                    continue
                si, ei = self.prot_lj.get(ptype, (1.9, 0.1))
                gj = ligand.atom_gaff_types[j] if j < len(ligand.atom_gaff_types) else 'c3'
                sj, ej = self.lig_lj.get(gj, (1.9, 0.1))
                sig = 0.5 * (si + sj)
                eps = math.sqrt(ei * ej)
                inv_r = 1.0 / d
                lj = 4.0 * eps * ((sig * inv_r)**12 - (sig * inv_r)**6)
                E += self.w_lj * lj
                if lig_q is not None:
                    qj = lig_q[j]
                    coul = COULOMB_CONST * pq * qj / (self.diel * d)
                    E += self.w_coulomb * coul
        return E

class LigandBridge:
    def __init__(self):
        self.ligands: List[Molecule] = []
        self.lig_energy = LigandEnergy()
        self.pl_energy = ProteinLigandEnergy()

    def add_ligand(self, lig: Molecule):
        self.ligands.append(lig)

    def load_ligand_file(self, fpath: str, ftype: str) -> int:
        if ftype == 'sdf':
            mols = read_sdf(fpath)
        elif ftype == 'mol2':
            mols = read_mol2(fpath)
        elif ftype == 'pdb':
            mols = read_pdb_ligand(fpath)
        else:
            raise ValueError(f"Unknown ligand format: {ftype}")
        for m in mols:
            self.ligands.append(m)
        return len(mols)

    def compute_ligand_energy(self) -> torch.Tensor:
        # fix device mismatch: start tensor on device of first ligand with coordinates
        device = None
        for lig in self.ligands:
            if lig.atom_coords is not None:
                device = lig.atom_coords.device
                break
        E = torch.tensor(0.0, device=device if device is not None else torch.device('cpu'))
        for lig in self.ligands:
            if lig.atom_coords is not None:
                E += self.lig_energy(lig)
        return E

    def compute_interaction(self, prot_coords: torch.Tensor,
                           prot_types: List[str],
                           prot_charges: List[float]) -> torch.Tensor:
        E = torch.tensor(0.0, device=prot_coords.device)
        for lig in self.ligands:
            E += self.pl_energy(prot_coords, prot_types, prot_charges, lig)
        return E

