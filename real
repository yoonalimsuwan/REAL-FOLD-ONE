class RosettaScorer:
    def __init__(self, cfg: Optional[Any] = None):
        self.w_intf = 15.0
        self.w_cross_lj = 30.0
        self.w_cross_coulomb = 5.0

    def score_complex(self, coords_ab: torch.Tensor, seq_ab: str,
                      coords_ag: torch.Tensor, seq_ag: str,
                      chi_ab: Optional[torch.Tensor] = None,
                      chi_ag: Optional[torch.Tensor] = None) -> torch.Tensor:
        device = coords_ab.device
        full_ca = torch.cat([coords_ab, coords_ag], dim=0)
        full_seq = seq_ab + seq_ag
        L_ab = len(seq_ab)
        # fixed: reuse one NeighborListManager instance
        nbr = NeighborListManager({'lj': 12.0, 'hb': 3.5}, 64, device=device)
        ei, ed = nbr.build(full_ca)['lj']
        atoms = reconstruct_backbone(full_ca)
        ei_hb, ed_hb = nbr.build(atoms['O'])['hb']
        alpha = torch.ones(len(full_seq), device=device)
        phi, psi = compute_phi_psi(atoms)
        E = torch.tensor(0.0, device=device)
        E += energy_bond(full_ca, alpha, w=30.0)
        E += energy_angle(full_ca, alpha, w=15.0)
        E += energy_rama(phi, psi, full_seq, alpha, w=8.0)
        E += energy_clash(full_ca, alpha, ei, ed, w=80.0)
        E += energy_hbond(atoms['O'], atoms['N'], atoms['C'], alpha, ei_hb, ed_hb, w=6.0)
        E += energy_electro(full_ca, full_seq, ei, ed, w=4.0)
        E += energy_solvent(full_ca, full_seq, ei, w=5.0)
        src, dst = ei[0], ei[1]
        cross = ((src < L_ab) & (dst >= L_ab)) | ((src >= L_ab) & (dst < L_ab))
        if cross.any():
            cs, cd = src[cross], dst[cross]
            d = ed[cross]
            q = torch.tensor([1 if a in 'RK' else -1 if a in 'DE' else 0 for a in full_seq], device=device)
            qi, qj = q[cs], q[cd]
            r = torch.clamp(d, min=1.0)
            lj = -4.0 * ((4.0 / r)**6 - (4.0 / r)**4)
            coul = -qi * qj / r
            E += self.w_cross_lj * lj.sum() + self.w_cross_coulomb * coul.sum()
        return E

class CDRLoopModeler:
    def __init__(self, scorer: RosettaScorer, frag_db: Optional[str] = None):
        self.scorer = scorer
        self.fragments = self._load_fragments(frag_db)

    def _load_fragments(self, path: Optional[str]) -> List[Tuple[float, float]]:
        if path and os.path.exists(path):
            with open(path) as f:
                return [tuple(x) for x in json.load(f)]
        return [(-65, -45), (-70, -40), (-60, -50), (-80, -30), (-55, -55),
                (-75, -35), (-62, -48), (-68, -42), (-58, -52), (-72, -38),
                (-90, -20), (-50, -60), (-85, -25), (-95, -15)]

    def remodel_loop(self, coords: torch.Tensor, seq: str,
                     loop_start: int, loop_end: int,
                     n_steps: int = 500, temp: float = 1.0) -> torch.Tensor:
        device = coords.device
        best_coords = coords.clone()
        current_coords = coords.clone()
        best_E = self.scorer.score_complex(
            current_coords[:loop_start], seq[:loop_start],
            current_coords[loop_end:], seq[loop_end:]
        ).item()
        for step in range(n_steps):
            if loop_end - loop_start < 2:
                continue
            pos = random.randint(loop_start, loop_end - 2)
            trial = current_coords.clone()
            trial[pos] += 0.5 * torch.randn(3, device=device)
            trial[pos + 1] += 0.5 * torch.randn(3, device=device)
            E_new = self.scorer.score_complex(
                trial[:loop_start], seq[:loop_start],
                trial[loop_end:], seq[loop_end:]
            ).item()
            delta = E_new - best_E
            if delta < 0 or random.random() < math.exp(-delta / temp):
                current_coords = trial
                if E_new < best_E:
                    best_E = E_new
                    best_coords = trial
        return best_coords

