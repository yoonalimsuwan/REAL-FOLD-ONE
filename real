class Molecule:
    def __init__(self, name: str = "UNK"):
        self.name = name
        self.atom_coords: Optional[torch.Tensor] = None
        self.atom_elements: List[str] = []
        self.atom_names: List[str] = []
        self.atom_gaff_types: List[str] = []
        self.atom_charges: Optional[torch.Tensor] = None
        self.bonds: List[Tuple[int, int]] = []
        self.bond_orders: List[float] = []
        self.angles: List[Tuple[int, int, int]] = []
        self.torsions: List[Tuple[int, int, int, int]] = []
        self.torsion_periodicities: List[int] = []
        self.impropers: List[Tuple[int, int, int, int]] = []
        self.n_atoms: int = 0

    def build_topology(self):
        if not self.bonds:
            return
        self.n_atoms = len(self.atom_elements)
        adj = defaultdict(set)
        for i, j in self.bonds:
            adj[i].add(j)
            adj[j].add(i)
        self.angles = []
        for j in range(self.n_atoms):
            neigh = list(adj[j])
            for a in range(len(neigh)):
                for b in range(a + 1, len(neigh)):
                    self.angles.append((neigh[a], j, neigh[b]))
        self.torsions = []
        self.torsion_periodicities = []
        for j, k in self.bonds:
            for i in adj[j]:
                if i != k:
                    for l in adj[k]:
                        if l != j and l != i:
                            period = 2 if self._is_sp2(j, k) else 3
                            self.torsions.append((i, j, k, l))
                            self.torsion_periodicities.append(period)
        self.impropers = []
        for j in range(self.n_atoms):
            if len(adj[j]) == 3:
                n = list(adj[j])
                self.impropers.append((j, n[0], n[1], n[2]))

    def _is_sp2(self, i: int, j: int) -> bool:
        for (a, b), o in zip(self.bonds, self.bond_orders):
            if (a == i and b == j) or (a == j and b == i):
                return o >= 1.5
        return False

    def assign_gaff_types(self):
        self.atom_gaff_types = []
        adj = defaultdict(set)
        for i, j in self.bonds:
            adj[i].add(j)
            adj[j].add(i)
        for i, e in enumerate(self.atom_elements):
            nb = len(adj[i])
            if e == 'C':
                if nb == 4:
                    gt = 'c3'
                elif nb == 3:
                    has_d = any(self._get_order(i, nei) >= 2.0 for nei in adj[i])
                    gt = 'c2' if has_d else 'ca'
                elif nb == 2:
                    gt = 'c1' if self._get_order(i, list(adj[i])[0]) >= 2.5 else 'c2'
                else:
                    gt = 'c3'
            elif e == 'N':
                if nb == 3:
                    gt = 'n3'
                elif nb == 2:
                    gt = 'n2'
                elif nb == 1:
                    gt = 'n1'
                else:
                    gt = 'n3'
            elif e == 'O':
                if nb == 1:
                    gt = 'o' if self._get_order(i, list(adj[i])[0]) >= 2.0 else 'oh'
                elif nb == 2:
                    gt = 'os'
                else:
                    gt = 'os'
            elif e == 'S':
                gt = 's' if nb <= 2 else 's6'
            else:
                gt = {'P': 'p5', 'F': 'f', 'Cl': 'cl', 'Br': 'br', 'I': 'i', 'H': 'h'}.get(e, e.lower())
            self.atom_gaff_types.append(gt)

    def _get_order(self, i: int, j: int) -> float:
        for (a, b), o in zip(self.bonds, self.bond_orders):
            if (a == i and b == j) or (a == j and b == i):
                return o
        return 1.0

    def to_device(self, device: torch.device) -> 'Molecule':
        if self.atom_coords is not None:
            self.atom_coords = self.atom_coords.to(device)
        if self.atom_charges is not None:
            self.atom_charges = self.atom_charges.to(device)
        return self

