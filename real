def reconstruct_backbone(ca: torch.Tensor) -> Dict[str, torch.Tensor]:
    L = ca.shape[0]
    device = ca.device
    N = torch.zeros_like(ca)
    C = torch.zeros_like(ca)
    O = torch.zeros_like(ca)
    if L == 1:
        N[0] = ca[0] - torch.tensor([1.45, 0, 0], device=device)
        C[0] = ca[0] + torch.tensor([1.52, 0, 0], device=device)
        O[0] = C[0] + torch.tensor([0, 1.23, 0], device=device)
        return {'N': N, 'CA': ca, 'C': C, 'O': O}
    for i in range(L):
        if i < L - 1:
            v_next = ca[i + 1] - ca[i]
            n_dir = ca[i - 1] - ca[i] if i > 0 else -v_next
            c_dir = v_next
        else:
            v_prev = ca[i - 1] - ca[i]
            n_dir = v_prev
            c_dir = -v_prev
        n_dir = _normalize(n_dir)
        c_dir = _normalize(c_dir)
        N[i] = ca[i] + 1.45 * n_dir
        C[i] = ca[i] + 1.52 * c_dir
        ca_c = C[i] - ca[i]
        ca_n = N[i] - ca[i]
        norm_vec = _normalize(torch.cross(ca_c, ca_n, dim=-1))
        O[i] = C[i] + 1.23 * norm_vec
    return {'N': N, 'CA': ca, 'C': C, 'O': O}

