# 7. Geometric Multigrid Poisson Solver (Differentiable)
# =============================================================================

class MultigridPoissonSolver(nn.Module):
    def __init__(self, n_levels: int = 3, n_smooth: int = 3):
        super().__init__()
        self.n_levels = n_levels
        self.n_smooth = n_smooth

    def _restrict(self, fine: torch.Tensor) -> torch.Tensor:
        return F.avg_pool3d(fine.unsqueeze(0).unsqueeze(0), 2, 2).squeeze(0).squeeze(0)

    def _prolong(self, coarse: torch.Tensor, shape: Tuple[int, ...]) -> torch.Tensor:
        return F.interpolate(coarse.unsqueeze(0).unsqueeze(0), size=shape,
                             mode='trilinear', align_corners=True).squeeze(0).squeeze(0)

    def solve(self, rho: torch.Tensor, epsilon: torch.Tensor,
              dx: float, tol: float = 1e-6, max_iter: int = 100) -> torch.Tensor:
        phi = torch.zeros_like(rho)
        residual = rho.clone()
        for _ in range(max_iter):
            for _ in range(self.n_smooth):
                phi_ip1 = torch.roll(phi, -1, 0)
                phi_im1 = torch.roll(phi, 1, 0)
                phi_jp1 = torch.roll(phi, -1, 1)
                phi_jm1 = torch.roll(phi, 1, 1)
                phi_kp1 = torch.roll(phi, -1, 2)
                phi_km1 = torch.roll(phi, 1, 2)
                eps_ip1 = torch.roll(epsilon, -1, 0)
                eps_im1 = torch.roll(epsilon, 1, 0)
                eps_jp1 = torch.roll(epsilon, -1, 1)
                eps_jm1 = torch.roll(epsilon, 1, 1)
                eps_kp1 = torch.roll(epsilon, -1, 2)
                eps_km1 = torch.roll(epsilon, 1, 2)
                numerator = (eps_ip1 * phi_ip1 + eps_im1 * phi_im1 +
                             eps_jp1 * phi_jp1 + eps_jm1 * phi_jm1 +
                             eps_kp1 * phi_kp1 + eps_km1 * phi_km1 -
                             dx**2 * rho)
                denominator = (eps_ip1 + eps_im1 + eps_jp1 + eps_jm1 +
                               eps_kp1 + eps_km1)
                phi = numerator / (denominator + 1e-8)
            residual_new = rho - self._apply_operator(phi, epsilon, dx)
            if torch.norm(residual_new) < tol:
                break
            residual = residual_new
        return phi

    def _apply_operator(self, phi: torch.Tensor, epsilon: torch.Tensor, dx: float) -> torch.Tensor:
        phi_ip1 = torch.roll(phi, -1, 0)
        phi_im1 = torch.roll(phi, 1, 0)
        phi_jp1 = torch.roll(phi, -1, 1)
        phi_jm1 = torch.roll(phi, 1, 1)
        phi_kp1 = torch.roll(phi, -1, 2)
        phi_km1 = torch.roll(phi, 1, 2)
        eps_ip1 = torch.roll(epsilon, -1, 0)
        eps_im1 = torch.roll(epsilon, 1, 0)
        eps_jp1 = torch.roll(epsilon, -1, 1)
        eps_jm1 = torch.roll(epsilon, 1, 1)
        eps_kp1 = torch.roll(epsilon, -1, 2)
        eps_km1 = torch.roll(epsilon, 1, 2)
        result = (eps_ip1 * (phi_ip1 - phi) + eps_im1 * (phi_im1 - phi) +
                  eps_jp1 * (phi_jp1 - phi) + eps_jm1 * (phi_jm1 - phi) +
                  eps_kp1 * (phi_kp1 - phi) + eps_km1 * (phi_km1 - phi)) / dx**2
        return result

