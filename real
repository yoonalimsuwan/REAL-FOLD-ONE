class PME:
    def __init__(self, grid_spacing=0.75, interpolation_order=4, alpha=None, box=None):
        self.grid_spacing = grid_spacing
        self.order = interpolation_order
        self.alpha = alpha
        self.box = box

    def _setup_grid(self, coords):
        if self.box is None:
            minc = coords.min(dim=0).values - 5.0
            maxc = coords.max(dim=0).values + 5.0
            box_size = maxc - minc
            L = box_size.max()
            minc = (minc + maxc)/2 - L/2
            maxc = minc + L
            box_vectors = torch.eye(3, device=coords.device) * L
            self.box = box_vectors
            self.inv_box = torch.inverse(box_vectors)
            self.ngrid = max(16, int(L / self.grid_spacing))
        return self.box, self.inv_box, self.ngrid

    def _spread(self, coords, q, inv_box, ngrid):
        frac = coords @ inv_box
        frac = frac - frac.floor()
        n = ngrid
        ix = (frac * n).long().clamp(0, n-1)
        wx = frac * n - ix.float()
        ix1 = (ix[:,0]+1) % n
        iy1 = (ix[:,1]+1) % n
        iz1 = (ix[:,2]+1) % n
        grid = torch.zeros((n,n,n), device=coords.device, dtype=coords.dtype)
        w000 = (1-wx[:,0])*(1-wx[:,1])*(1-wx[:,2])
        w100 = wx[:,0]*(1-wx[:,1])*(1-wx[:,2])
        w010 = (1-wx[:,0])*wx[:,1]*(1-wx[:,2])
        w001 = (1-wx[:,0])*(1-wx[:,1])*wx[:,2]
        w110 = wx[:,0]*wx[:,1]*(1-wx[:,2])
        w101 = wx[:,0]*(1-wx[:,1])*wx[:,2]
        w011 = (1-wx[:,0])*wx[:,1]*wx[:,2]
        w111 = wx[:,0]*wx[:,1]*wx[:,2]
        idx = (ix[:,0], ix[:,1], ix[:,2])
        idx100 = (ix1, ix[:,1], ix[:,2])
        idx010 = (ix[:,0], iy1, ix[:,2])
        idx001 = (ix[:,0], ix[:,1], iz1)
        idx110 = (ix1, iy1, ix[:,2])
        idx101 = (ix1, ix[:,1], iz1)
        idx011 = (ix[:,0], iy1, iz1)
        idx111 = (ix1, iy1, iz1)
        grid.index_put_(idx, q*w000, accumulate=True)
        grid.index_put_(idx100, q*w100, accumulate=True)
        grid.index_put_(idx010, q*w010, accumulate=True)
        grid.index_put_(idx001, q*w001, accumulate=True)
        grid.index_put_(idx110, q*w110, accumulate=True)
        grid.index_put_(idx101, q*w101, accumulate=True)
        grid.index_put_(idx011, q*w011, accumulate=True)
        grid.index_put_(idx111, q*w111, accumulate=True)
        return grid

    def _solve_recip(self, grid, box, ngrid, alpha):
        kx = torch.fft.fftfreq(ngrid, d=box[0,0]/ngrid).to(grid.device)
        ky = torch.fft.fftfreq(ngrid, d=box[1,1]/ngrid).to(grid.device)
        kz = torch.fft.fftfreq(ngrid, d=box[2,2]/ngrid).to(grid.device)
        KX, KY, KZ = torch.meshgrid(kx, ky, kz, indexing='ij')
        k2 = KX**2 + KY**2 + KZ**2
        k2[0,0,0] = 1.0
        B = torch.exp(-k2 / (4 * alpha**2)) / k2
        B[0,0,0] = 0.0
        Qk = torch.fft.fftn(grid)
        Ek = B * Qk.abs()**2
        E = 0.5 * Ek.sum().real * (box[0,0]*box[1,1]*box[2,2] / ngrid**3)
        return E

    def energy(self, coords, q):
        if coords.shape[0] == 0: return torch.tensor(0.0, device=coords.device)
        box, inv_box, ngrid = self._setup_grid(coords)
        if self.alpha is None:
            L = box.diag().max()
            self.alpha = 0.4 / self.grid_spacing
        grid = self._spread(coords, q, inv_box, ngrid)
        E_recip = self._solve_recip(grid, box, ngrid, self.alpha)
        self_energy = -self.alpha / math.sqrt(math.pi) * (q**2).sum()
        return E_recip + self_energy

class MultigridPoisson:
    def __init__(self, finest_spacing=0.5, levels=3, box=None):
        self.finest_spacing = finest_spacing
        self.levels = levels
        self.box = box

    def _setup_grids(self, coords):
        if self.box is None:
            minc = coords.min(dim=0).values - 5.0
            maxc = coords.max(dim=0).values + 5.0
            L = (maxc - minc).max()
            box_vectors = torch.eye(3, device=coords.device) * L
            self.box = box_vectors
            self.inv_box = torch.inverse(box_vectors)
            self.n_finest = max(16, int(L / self.finest_spacing))
        self.grids = []
        n = self.n_finest
        for _ in range(self.levels):
            n = max(2, n)
            self.grids.append(n)
            n = n // 2

    def _charge_grid(self, coords, q, n, inv_box):
        frac = coords @ inv_box
        idx = (frac * n).long().clamp(0, n-1)
        grid = torch.zeros((n,n,n), device=coords.device, dtype=coords.dtype)
        grid.index_put_((idx[:,0], idx[:,1], idx[:,2]), q, accumulate=True)
        return grid

    def _laplacian(self, u):
        u_xx = torch.roll(u, -1, dims=0) + torch.roll(u, 1, dims=0) - 2*u
        u_yy = torch.roll(u, -1, dims=1) + torch.roll(u, 1, dims=1) - 2*u
        u_zz = torch.roll(u, -1, dims=2) + torch.roll(u, 1, dims=2) - 2*u
        return u_xx + u_yy + u_zz

    def _smooth(self, u, f, nu=2, weight=2/3):
        for _ in range(nu):
            u = u + weight * (u + f/6 - u)
        return u

    def _restrict(self, r):
        return 0.125 * r[::2, ::2, ::2]

    def _prolong(self, e):
        return F.interpolate(e.unsqueeze(0).unsqueeze(0), scale_factor=2, mode='trilinear', align_corners=False).squeeze()

    def _v_cycle(self, u, f, level):
        if level == self.levels - 1:
            n = u.shape[0]
            kx = torch.fft.fftfreq(n, d=1.0/n).unsqueeze(1).unsqueeze(2)
            ky = torch.fft.fftfreq(n, d=1.0/n).unsqueeze(0).unsqueeze(2)
            kz = torch.fft.fftfreq(n, d=1.0/n).unsqueeze(0).unsqueeze(1)
            k2 = (kx**2 + ky**2 + kz**2) * (2*math.pi)**2
            k2[0,0,0] = 1.0
            fk = torch.fft.fftn(f)
            uk = fk / (-k2)
            uk[0,0,0] = 0.0
            u = torch.fft.ifftn(uk).real
            return u
        u = self._smooth(u, f, nu=2)
        r = f - self._laplacian(u)
        r_coarse = self._restrict(r)
        e_coarse = torch.zeros_like(r_coarse)
        e_coarse = self._v_cycle(e_coarse, r_coarse, level+1)
        u += self._prolong(e_coarse)
        u = self._smooth(u, f, nu=2)
        return u

    def solve(self, coords, q):
        if coords.shape[0] == 0: return torch.tensor(0.0, device=coords.device)
        self._setup_grids(coords)
        n_f = self.grids[0]
        vol = (self.box[0,0]/n_f)**3
        rho_f = self._charge_grid(coords, q, n_f, self.inv_box) * 4 * math.pi / vol
        u = torch.zeros_like(rho_f)
        u = self._v_cycle(u, rho_f, level=0)
        frac = coords @ self.inv_box
        idx = (frac * n_f).long().clamp(0, n_f-1)
        phi = u[idx[:,0], idx[:,1], idx[:,2]]
        E = 0.5 * (q * phi).sum()
        return E

class BlockwiseLongRange:
    def __init__(self, block_size=12.0, cutoff=12.0):
        self.block_size = block_size
        self.cutoff = cutoff

    def compute_energy(self, coords, q, direct_edge, direct_dist):
        N = coords.shape[0]
        device = coords.device
        if N == 0: return torch.tensor(0.0, device=device)
        minc = coords.min(dim=0).values
        block_idx = ((coords - minc) / self.block_size).long()
        unique_blocks, block_numbers = torch.unique(block_idx, dim=0, return_inverse=True)
        B = unique_blocks.shape[0]
        block_charge = torch.zeros(B, device=device)
        block_dipole = torch.zeros(B, 3, device=device)
        block_charge.scatter_add_(0, block_numbers, q)
        for d in range(3):
            block_dipole[:, d].scatter_add_(0, block_numbers, q * coords[:, d])
        block_centers = (unique_blocks.float() + 0.5) * self.block_size + minc
        E_lr = torch.tensor(0.0, device=device)
        for i in range(B):
            ci = block_centers[i]; qi = block_charge[i]; di = block_dipole[i]
            for j in range(i+1, B):
                cj = block_centers[j]; qj = block_charge[j]; dj = block_dipole[j]
                r_vec = ci - cj; r = torch.norm(r_vec) + 1e-8
                if r < self.cutoff: continue
                r3 = r**3; r5 = r**5
                E_cc = qi * qj / r
                E_cd = (qi * torch.dot(dj, r_vec) - qj * torch.dot(di, r_vec)) / r3
                E_dd = (torch.dot(di, dj) * r**2 - 3 * torch.dot(di, r_vec) * torch.dot(dj, r_vec)) / r5
                E_lr += E_cc + E_cd + E_dd
        return E_lr * 332.0637

