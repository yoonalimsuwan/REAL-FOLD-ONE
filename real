# 16. Explicit Solvent Builder
# =============================================================================
class SolventBuilder:
    """Create a TIP3P water box around solute and add counterions."""
    def __init__(self, pad=10.0, ion_conc=0.15, device='cpu'):
        self.pad = pad
        self.ion_conc = ion_conc  # mol/L
        self.device = device
        # TIP3P geometry
        self.oh_dist = 0.9572
        self.hoh_angle = 104.52 * math.pi / 180
        self.water_q = [ -0.834, 0.417, 0.417 ]  # O, H, H

    def build(self, solute_coords, solute_types, solute_charges):
        """Return water/ion coords, types, charges, and box size."""
        device = solute_coords.device
        minc = solute_coords.min(dim=0).values - self.pad
        maxc = solute_coords.max(dim=0).values + self.pad
        box_size = maxc - minc
        # Number of water molecules based on density
        water_density = 0.0334  # molecules/Å^3 (TIP3P density ~1.0 g/mL)
        n_waters = int(water_density * box_size.prod().item())
        # Generate water positions on a grid, then randomize
        grid_spacing = 2.8  # approx spacing for water
        nx = max(1, int(box_size[0]/grid_spacing))
        ny = max(1, int(box_size[1]/grid_spacing))
        nz = max(1, int(box_size[2]/grid_spacing))
        water_origins = []
        for i in range(nx):
            for j in range(ny):
                for k in range(nz):
                    pos = minc + torch.tensor([i*grid_spacing, j*grid_spacing, k*grid_spacing], device=device)
                    # Avoid placing water too close to solute
                    too_close = False
                    for sc in solute_coords:
                        if torch.norm(pos - sc) < 2.0:
                            too_close = True
                            break
                    if not too_close:
                        water_origins.append(pos)
        # Randomly select up to n_waters
        if len(water_origins) > n_waters:
            selected = random.sample(water_origins, n_waters)
        else:
            selected = water_origins
        water_coords = []
        water_types = []
        for ow in selected:
            # Generate two hydrogens with TIP3P geometry
            # Random orientation
            rand_dir = torch.randn(3, device=device)
            rand_dir = _normalize(rand_dir)
            # First H
            h1 = ow + self.oh_dist * rand_dir
            # Second H: rotate around oxygen by angle
            axis = torch.randn(3, device=device)
            axis = _normalize(torch.cross(rand_dir, axis))
            # Rotate rand_dir by hoh_angle around axis using Rodrigues' formula
            cos_ang = math.cos(self.hoh_angle)
            sin_ang = math.sin(self.hoh_angle)
            h2 = ow + self.oh_dist * (rand_dir * cos_ang + torch.cross(axis, rand_dir) * sin_ang + axis * torch.dot(axis, rand_dir) * (1 - cos_ang))
            water_coords.append(ow)
            water_types.append('OW')
            water_coords.append(h1)
            water_types.append('HW1')
            water_coords.append(h2)
            water_types.append('HW2')
        water_coords_tensor = torch.stack(water_coords, dim=0)
        water_charges = []
        for _ in selected:
            water_charges.extend(self.water_q)
        water_charges_tensor = torch.tensor(water_charges, device=device)
        # Add ions (Na+ and Cl-)
        net_charge = solute_charges.sum().item()
        n_ions = max(0, int(n_waters * self.ion_conc / 55.5))  # approx 55.5 M water
        # Neutralize system
        n_na = max(0, -int(net_charge))
        n_cl = max(0, int(net_charge))
        # Add extra salt pairs
        n_na += n_ions
        n_cl += n_ions
        ion_coords = []
        ion_types = []
        for _ in range(n_na):
            pos = minc + torch.rand(3, device=device) * box_size
            ion_coords.append(pos)
            ion_types.append('Na+')
        for _ in range(n_cl):
            pos = minc + torch.rand(3, device=device) * box_size
            ion_coords.append(pos)
            ion_types.append('Cl-')
        if ion_coords:
            ion_coords_tensor = torch.stack(ion_coords, dim=0)
        else:
            ion_coords_tensor = torch.empty((0,3), device=device)
        all_solvent_coords = torch.cat([water_coords_tensor, ion_coords_tensor], dim=0)
        all_solvent_types = water_types + ion_types
        all_solvent_charges = torch.cat([water_charges_tensor, 
                                         torch.tensor([1.0]*n_na + [-1.0]*n_cl, device=device)])
        return all_solvent_coords, all_solvent_types, all_solvent_charges, box_size

