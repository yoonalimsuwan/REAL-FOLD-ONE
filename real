@dataclass
class RefinementConfig:
    w_bond: float = 30.0; w_angle: float = 15.0; w_rama: float = 8.0; w_clash: float = 80.0
    w_hbond: float = 6.0; w_electro: float = 4.0; w_solvent: float = 5.0; w_soc: float = 0.3
    w_alpha_entropy: float = 0.5; w_alpha_smooth: float = 0.1; w_chain_break: float = 1.0
    w_lj: float = 30.0; w_coulomb: float = 5.0; w_torsion: float = 10.0
    clash_radius: float = 2.0; angle_target_rad: float = 111.0*math.pi/180.0; bond_target: float = 3.8
    base_temp: float = 300.0; friction: float = 0.02; sigma_target: float = 1.0
    avalanche_threshold: float = 0.5; w_avalanche: float = 0.2
    cutoff: float = 12.0; max_neighbors: int = 64
    lr: float = 1e-4; steps: int = 600; rebuild_interval: int = 100
    use_amp: bool = True; grad_clip: float = 5.0; use_milstein: bool = False
    use_rg: bool = True; rg_factor: int = 4; rg_interval: int = 200
    use_ssc: bool = True; epsilon_fp: float = 0.0028
    dna_full_atom: bool = True
    use_pme: bool = False; pme_grid_spacing: float = 0.75
    use_multigrid: bool = False; multigrid_levels: int = 3
    use_block_lr: bool = False; block_size: float = 12.0
    device: str = "cuda" if torch.cuda.is_available() else "cpu"
    anneal_start: float = 1000.0
    anneal_end: float = 300.0
    anneal_cycles: int = 1
    use_explicit_solvent: bool = False
    ph: float = 7.0
    water_box_pad: float = 10.0
    ion_conc: float = 0.15
    use_respa: bool = False
    respa_nslow: int = 4
    respa_nfast: int = 4

class RefinementEngine:
    def __init__(self, cfg: Optional[RefinementConfig] = None):
        self.cfg = cfg or RefinementConfig()
        self.device = torch.device(self.cfg.device)
        self.kernel = CSOCKernel(init_alpha=0.5, init_lambda=12.0)
        self.soc = SOCController(
            base_temp=self.cfg.base_temp, friction=self.cfg.friction,
            sigma_target=self.cfg.sigma_target, avalanche_threshold=self.cfg.avalanche_threshold,
            w_avalanche=self.cfg.w_avalanche, kernel=self.kernel,
            use_ssc=self.cfg.use_ssc, epsilon_fp=self.cfg.epsilon_fp,
            adaptive_friction=True
        )
        self.rg = DiffRGRefiner(self.cfg.rg_factor) if self.cfg.use_rg else None
        self.scaler = GradScaler(enabled=self.cfg.use_amp and self.device.type == 'cuda')
        self.pme = PME(grid_spacing=self.cfg.pme_grid_spacing) if self.cfg.use_pme else None
        self.mg = MultigridPoisson(finest_spacing=0.5, levels=self.cfg.multigrid_levels) if self.cfg.use_multigrid else None
        self.block_lr = BlockwiseLongRange(block_size=self.cfg.block_size, cutoff=self.cfg.cutoff) if self.cfg.use_block_lr else None
        self.neighbor_mgr = NeighborListManager(
            cutoffs={'clash':2.5, 'lj':6.0, 'elec':self.cfg.cutoff},
            max_neighbors=self.cfg.max_neighbors,
            device=self.device
        )
        self.protonation_fixer = ProtonationFixer(ph=self.cfg.ph)

    def _build_edges(self, coords, batch=None):
        return self.neighbor_mgr.build(coords, batch)

    def _temperature_schedule(self, step, total_steps):
        if self.cfg.anneal_cycles <= 0:
            return self.cfg.base_temp
        cycle_len = total_steps // self.cfg.anneal_cycles
        cycle_step = step % cycle_len
        frac = cycle_step / cycle_len
        T = self.cfg.anneal_start + (self.cfg.anneal_end - self.cfg.anneal_start) * frac
        return max(T, self.cfg.anneal_end)

    def _total_energy(self, ca, seq, alpha, chi,
                      edge_dict, edge_hb, edge_hb_dist,
                      boundaries, chain_types, mask,
                      ligand_bridge=None, solvent_data=None):
        E = torch.tensor(0.0, device=ca.device)
        atoms = reconstruct_backbone(ca)
        phi, psi = compute_phi_psi(atoms)
        prot_mask = torch.tensor([t=='protein' for t in chain_types], device=ca.device) if mask is None else mask

        E += energy_bond(ca, alpha, self.cfg.w_bond, mod=0.1, target=self.cfg.bond_target, mask=prot_mask)
        E += energy_angle(ca, alpha, self.cfg.w_angle, mod=0.05, target_rad=self.cfg.angle_target_rad, mask=prot_mask)
        E += energy_rama(phi, psi, seq, alpha, self.cfg.w_rama, mod=0.2, mask=prot_mask)
        E += energy_clash(ca, alpha, edge_dict['clash'][0], edge_dict['clash'][1], self.cfg.w_clash, self.cfg.clash_radius, mod=0.1, mask=prot_mask)
        E += energy_hbond(atoms['O'], atoms['N'], atoms['C'], alpha, edge_hb, edge_hb_dist, self.cfg.w_hbond, mod=0.1, mask=prot_mask)

        elec_edge, elec_dist = edge_dict['elec']
        q_res = torch.tensor([RESIDUE_CHARGE.get(a,0.0) for a in seq], device=ca.device)
        if self.cfg.use_pme:
            E += self.pme.energy(ca, q_res)
        elif self.cfg.use_multigrid:
            E += self.mg.solve(ca, q_res)
        else:
            E += energy_electro(ca, seq, elec_edge, elec_dist, self.cfg.w_electro, mask=prot_mask)
            if self.block_lr:
                E += self.block_lr.compute_energy(ca, q_res, elec_edge, elec_dist)

        E += energy_solvent(ca, seq, elec_edge, self.cfg.w_solvent, mask=prot_mask)
        E += self.soc.compute_soc_energy(ca, alpha, elec_edge, elec_dist, mask=prot_mask, w_soc=self.cfg.w_soc)
        E += alpha_regularisation(alpha, self.cfg.w_alpha_entropy, self.cfg.w_alpha_smooth)
        E += chain_break_energy(ca, boundaries, self.cfg.w_chain_break)

        dna_mask = torch.tensor([t in ('dna','rna') for t in chain_types], device=ca.device)
        if dna_mask.any():
            idx = torch.where(dna_mask)[0]
            if len(idx) > 0:
                dna_ca = ca[idx]
                dna_seq = "".join([seq[i] for i in idx.tolist()])
                if self.cfg.dna_full_atom:
                    E += energy_dna_rna_full(dna_ca, dna_seq,
                                             w_bp=8.0, w_stack=5.0, w_backbone=30.0,
                                             w_lj=self.cfg.w_lj, w_coulomb=self.cfg.w_coulomb,
                                             cutoff=self.cfg.cutoff, max_neighbors=self.cfg.max_neighbors)
                else:
                    for i in range(len(dna_seq)):
                        for j in range(i+4, min(len(dna_seq),i+50)):
                            d = torch.norm(dna_ca[i]-dna_ca[j])
                            n = WC_PAIRS.get((dna_seq[i],dna_seq[j]),0)
                            if n>0:
                                E += -n * 8.0 * torch.exp(-((d-10.5)/2.0)**2)
                        if i < len(dna_seq)-1:
                            d = torch.norm(dna_ca[i+1]-dna_ca[i])
                            s = 0.5*(BASE_STACKING.get(dna_seq[i],1.0)+BASE_STACKING.get(dna_seq[i+1],1.0))
                            E += -s * 5.0 * torch.exp(-((d-6.5)/1.5)**2)

        if chi is not None and prot_mask.any():
            prot_idx = torch.where(prot_mask)[0]
            if len(prot_idx) > 0:
                prot_ca = ca[prot_idx]
                prot_seq = "".join([seq[i] for i in prot_idx.tolist()])
                prot_chi = chi[prot_idx]
                all_c, all_t, _ = get_full_atom_coords_and_types(prot_ca, prot_seq, prot_chi)
                if all_c.shape[0] > 0:
                    ei_full, ed_full = self.neighbor_mgr.build(all_c)['lj']
                    E += energy_lj_full(all_c, all_t, _, ei_full, ed_full, DEFAULT_LJ_PARAMS, self.cfg.w_lj)


                    E += energy_coulomb_full(all_c, all_t, _, ei_full, ed_full, DEFAULT_CHARGE_MAP, self.cfg.w_coulomb)

                    E += energy_torsion_chi(prot_chi, prot_seq, self.cfg.w_torsion)

        if ligand_bridge is not None and prot_mask.any():
            prot_idx = torch.where(prot_mask)[0]
            if len(prot_idx) > 0:
                prot_ca = ca[prot_idx]; prot_seq = "".join([seq[i] for i in prot_idx.tolist()])
                prot_chi = chi[prot_idx] if chi is not None else None
                prot_all, prot_types, _ = get_full_atom_coords_and_types(prot_ca, prot_seq, prot_chi)
                if prot_all.shape[0] > 0:
                    prot_charges = [DEFAULT_CHARGE_MAP.get(t, 0.0) for t in prot_types]
                    E += ligand_bridge.compute_ligand_energy()
                    E += ligand_bridge.compute_interaction(prot_all, prot_types, prot_charges)
        return E

    def refine(self, coords, sequence, mask=None, chain_types=None, chain_boundaries=None,
               ligand_files=None, steps=None, logger=None, return_trajectory=False) -> Dict:
        if steps is None: steps = self.cfg.steps
        if isinstance(coords, np.ndarray):
            coords = torch.tensor(coords, dtype=torch.float32, device=self.device)
        elif isinstance(coords, torch.Tensor):
            coords = coords.to(self.device).float()
        else:
            raise ValueError("coords must be numpy array or torch tensor")

        if coords.dim() == 2: coords = coords.unsqueeze(0)
        B, L, _ = coords.shape
        if B > 1:
            coords = coords.view(-1, 3)
        else:
            coords = coords.squeeze(0).detach().requires_grad_(True)
        L = len(sequence)

        if mask is None: mask = torch.ones(L, dtype=torch.bool, device=self.device)
        else: mask = torch.tensor(mask, dtype=torch.bool, device=self.device)

        if chain_types is None:
            chain_types = [detect_sequence_type(sequence[i:i+1]) for i in range(L)]
        if chain_boundaries is None: chain_boundaries = []

        max_chi = 4
        chi = torch.zeros(L, max_chi, device=self.device, requires_grad=True)
        alpha = torch.ones(L, device=self.device, requires_grad=True)

        ligand_bridge = None
        ligand_params = []
        if ligand_files:
            ligand_bridge = LigandBridge()
            for f in ligand_files:
                ext = os.path.splitext(f)[1].lower().lstrip('.')
                ftype = 'sdf' if ext in ('sdf','') else 'mol2' if ext=='mol2' else 'pdb' if ext=='pdb' else 'sdf'
                ligand_bridge.load_ligand_file(f, ftype)
            for lig in ligand_bridge.ligands:
                lig.to_device(self.device)
                lig.atom_coords = lig.atom_coords.detach().requires_grad_(True)
                ligand_params.append(lig.atom_coords)

        edge_dict = self._build_edges(coords)
        atoms = reconstruct_backbone(coords)
        edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, self.cfg.max_neighbors).build(atoms['O'])['hb']

        params = [coords, chi, alpha] + ligand_params
        optimizer = torch.optim.Adam(params, lr=self.cfg.lr)
        energy_history = []
        best_energy = float('inf')
        best_coords = coords.clone()
        best_chi = chi.clone()
        best_alpha = alpha.clone()
        trajectory = [] if return_trajectory else None

        for step in range(steps):
            # Temperature scheduling
            T_anneal = self._temperature_schedule(step, steps)
            # Override SOC temperature only if anneal is active
            self.soc.base_temp = T_anneal if self.cfg.anneal_cycles > 0 else self.cfg.base_temp

            optimizer.zero_grad()
            with autocast(enabled=self.cfg.use_amp and self.device.type == 'cuda'):
                E = self._total_energy(coords, sequence, alpha, chi,
                                       edge_dict, edge_hb, edge_hb_dist,
                                       chain_boundaries, chain_types, mask,
                                       ligand_bridge)
                loss = E
            self.scaler.scale(loss).backward()

            av_grad = self.soc.avalanche_gradient(coords, alpha, edge_dict['elec'][0], edge_dict['elec'][1])
            if av_grad is not None:
                if coords.grad is not None: coords.grad = coords.grad + av_grad
                else: coords.grad = av_grad

            self.scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(params, self.cfg.grad_clip)
            self.scaler.step(optimizer)
            self.scaler.update()

            sigma = self.soc.sigma(coords.detach())
            T = self.soc.temperature(sigma)
            noise_scale = math.sqrt(2 * self.cfg.friction * T.item() / 300.0) * self.cfg.lr
            with torch.no_grad():
                coords.add_(torch.randn_like(coords) * noise_scale)
                chi.data.add_(torch.randn_like(chi) * noise_scale * 0.5)
                for lc in ligand_params: lc.add_(torch.randn_like(lc) * noise_scale * 0.1)

            if self.rg and step > 0 and step % self.cfg.rg_interval == 0:
                coords.data = self.rg.forward(coords.data)

            if step > 0 and step % self.cfg.rebuild_interval == 0:
                edge_dict = self._build_edges(coords.detach())
                atoms = reconstruct_backbone(coords.detach())
                edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, self.cfg.max_neighbors).build(atoms['O'])['hb']

            if loss.item() < best_energy:
                best_energy = loss.item()
                best_coords = coords.clone().detach()
                best_chi = chi.clone().detach()
                best_alpha = alpha.clone().detach()

            if logger and step % 50 == 0:
                logger.info(f"step {step:04d}  E={loss.item():.4f}  σ={sigma.item():.3f}  T={T.item():.1f}")
            energy_history.append(loss.item())
            if return_trajectory:
                trajectory.append(best_coords.cpu().clone())

        # Restore base temp
        self.soc.base_temp = self.cfg.base_temp
        return {
            'coords': best_coords.cpu().numpy(),
            'chi': best_chi.cpu().numpy(),
            'alpha': best_alpha.cpu().numpy(),
            'energy_history': energy_history,
            'final_energy': best_energy,
            'sigma': sigma.item(),
            'temperature': T.item(),
            'trajectory': np.stack(trajectory) if return_trajectory else None
        }

    def compute_energy(self, coords, sequence, chain_types=None, mask=None, chi=None, alpha=None) -> float:
        if coords.dim() == 2: coords = coords.unsqueeze(0)
        coords = coords.view(-1, 3)
        L = len(sequence)
        if mask is None: mask = torch.ones(L, dtype=torch.bool, device=coords.device)
        if chain_types is None: chain_types = [detect_sequence_type(sequence[i:i+1]) for i in range(L)]
        if chi is None: chi = torch.zeros(L, 4, device=coords.device)
        if alpha is None: alpha = torch.ones(L, device=coords.device)

        edge_dict = self._build_edges(coords)
        atoms = reconstruct_backbone(coords)
        edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, self.cfg.max_neighbors).build(atoms['O'])['hb']
        E = self._total_energy(coords, sequence, alpha, chi,
                               edge_dict, edge_hb, edge_hb_dist,
                               [], chain_types, mask)
        return E.item()

    def relax_local(self, coords, sequence, positions, steps=30, window=3,
                    chain_types=None, mask=None, chi=None, alpha=None):
        if coords.dim() == 2: coords = coords.unsqueeze(0)
        coords = coords.view(-1, 3).detach().requires_grad_(True)
        L = len(sequence)
        if mask is None: mask = torch.ones(L, dtype=torch.bool, device=coords.device)
        if chain_types is None: chain_types = [detect_sequence_type(sequence[i:i+1]) for i in range(L)]
        if chi is None: chi = torch.zeros(L, 4, device=coords.device)
        if alpha is None: alpha = torch.ones(L, device=coords.device)

        min_pos = min(positions); max_pos = max(positions)
        win_start = max(0, min_pos - window); win_end = min(L, max_pos + window + 1)

        opt = torch.optim.Adam([coords], lr=self.cfg.lr)
        best_E = float('inf')
        best_coords = coords.clone()

        edge_dict = self._build_edges(coords)
        atoms = reconstruct_backbone(coords)
        edge_hb, edge_hb_dist = NeighborListManager({'hb':3.5}, self.cfg.max_neighbors).build(atoms['O'])['hb']

        for _ in range(steps):
            opt.zero_grad()
            E = self._total_energy(coords, sequence, alpha, chi,
                                   edge_dict, edge_hb, edge_hb_dist,
                                   [], chain_types, mask)
            E.backward()
            if coords.grad is not None:
                grad_mask = torch.zeros(L, 3, device=coords.device)
                grad_mask[win_start:win_end] = 1.0
                coords.grad *= grad_mask
            opt.step()
            if E.item() < best_E:
                best_E = E.item()
                best_coords = coords.clone().detach()
        return best_coords.detach(), best_E


# =============================================================================
# 19. Training Module – Learnable SOC kernel and energy weights
# =============================================================================
class Trainer:
    """Fine‑tune SOC kernel parameters or energy weights from a set of PDB files."""
    def __init__(self, cfg: RefinementConfig = None):
        self.cfg = cfg or RefinementConfig()
        self.engine = RefinementEngine(self.cfg)
        self.kernel = self.engine.kernel

    def load_structures(self, file_list):
        """Load multiple PDB/mmCIF files, return list of (coords, sequence)."""
        data = []
        for fpath in file_list:
            if not HAS_BIOTITE:
                raise ImportError("biotite required for training")
            struct = load_structure(fpath)  # see I/O Utilities below
            data.append((struct['coords'], struct['sequence']))
        return data

    def train(self, file_list, epochs=100, lr=1e-3, use_full_atom=False, verbose=True):
        """
        Train kernel parameters (log_alpha, log_lambda) to minimise the energy
        of native structures.  Returns final alpha and lambda.
        """
        structures = self.load_structures(file_list)
        # Only optimise kernel parameters
        optimizer = torch.optim.Adam(self.kernel.parameters(), lr=lr)
        for epoch in range(epochs):
            total_loss = 0.0
            for coords_np, seq in structures:
                coords = torch.tensor(coords_np, dtype=torch.float32, device=self.engine.device)
                if use_full_atom:
                    # Use full‑atom energy (sidechains rebuilt)
                    chi = torch.zeros(len(seq), MAX_CHI, device=self.engine.device)
                    alpha = torch.ones(len(seq), device=self.engine.device)
                    E = self.engine._total_energy(
                        coords, seq, alpha, chi,
                        self.engine._build_edges(coords),
                        torch.empty(2,0), torch.empty(0),
                        [], ['protein']*len(seq), None
                    )
                else:
                    E = self.engine.compute_energy(coords, seq)
                loss = E  # minimise native energy
                optimizer.zero_grad()
                loss.backward()
                optimizer.step()
                total_loss += loss.item()
            if verbose and epoch % max(1, epochs//10) == 0:
                print(f"Epoch {epoch:4d}  avg_loss={total_loss/len(structures):.4f}  "
                      f"α={self.kernel.alpha.item():.4f}  λ={self.kernel.lambd.item():.4f}")
        return self.kernel.alpha.item(), self.kernel.lambd.item()


# =============================================================================
# 20. I/O Utilities (shared by training and CLI)
# =============================================================================
def load_structure(filepath, chain=None):
    """Load PDB or mmCIF and return dict with coords, sequence, chain_ids."""
    if not HAS_BIOTITE:
        raise ImportError("biotite required for structure I/O")
    if filepath.endswith('.pdb'):
        struct = pdb_io.PDBFile.read(filepath).get_structure(model=1)
    elif filepath.endswith('.cif') or filepath.endswith('.mmcif'):
        struct = mmcif_io.MMCIFFile.read(filepath).get_structure(model=1)
    else:
        raise ValueError("File must be .pdb or .cif/.mmcif")
    if chain is not None:
        struct = struct[struct.chain_id == chain]
    ca = struct[struct.atom_name == "CA"]
    coords = ca.coord.astype(np.float32)
    seq = [AA_3_TO_1.get(res.res_name, 'X') for res in ca.residues]
    return {'coords': coords, 'sequence': "".join(seq), 'chain_ids': list(ca.chain_id)}

def save_structure(coords, sequence, filename, chain_id='A'):
    """Save CA‑only PDB file."""
    with open(filename, 'w') as f:
        for i, (x,y,z) in enumerate(coords):
            aa = sequence[i] if i < len(sequence) else 'X'
            f.write(f"ATOM  {i+1:5d}  CA  {aa:3s} {chain_id}{i+1:4d}    "
                    f"{x:8.3f}{y:8.3f}{z:8.3f}  1.00  0.00           C\n")
        f.write("END\n")
    print(f"Saved CA‑only PDB to {filename}")


# =============================================================================
# 21. Command Line Interface
# =============================================================================
def main():
    parser = argparse.ArgumentParser(description="REAL FOLD ONE – SOC Refinement Engine")
    sub = parser.add_subparsers(dest='command', required=True)

    # refine
    refine_parser = sub.add_parser('refine', help='Refine a protein/DNA structure')
    refine_parser.add_argument('--input','-i', required=True)
    refine_parser.add_argument('--chain', default=None)
    refine_parser.add_argument('--output','-o', default='refined.pdb')
    refine_parser.add_argument('--steps', type=int, default=600)
    refine_parser.add_argument('--lr', type=float, default=1e-4)
    refine_parser.add_argument('--ligand', nargs='+')
    refine_parser.add_argument('--boundaries', nargs='+', type=int)
    refine_parser.add_argument('--device', default='auto')
    refine_parser.add_argument('--no_rg', action='store_true')
    refine_parser.add_argument('--no_ssc', action='store_true')
    refine_parser.add_argument('--trajectory', action='store_true')
    refine_parser.add_argument('--milstein', action='store_true')
    refine_parser.add_argument('--pme', action='store_true')
    refine_parser.add_argument('--multigrid', action='store_true')
    refine_parser.add_argument('--block_lr', action='store_true')
    refine_parser.add_argument('--full_atom', action='store_true', help='Export full‑atom PDB')

    # train
    train_parser = sub.add_parser('train', help='Train SOC kernel on native structures')
    train_parser.add_argument('--input', nargs='+', required=True, help='List of PDB files')
    train_parser.add_argument('--epochs', type=int, default=100)
    train_parser.add_argument('--lr', type=float, default=1e-3)
    train_parser.add_argument('--full_atom', action='store_true', help='Use full‑atom energy')
    train_parser.add_argument('--output', default='kernel_params.json', help='Save kernel parameters')

    # antibody
    ab_parser = sub.add_parser('antibody', help='Antibody CDR loop modelling')
    ab_parser.add_argument('--antigen', required=True)
    ab_parser.add_argument('--cdr_start', type=int, default=95)
    ab_parser.add_argument('--cdr_end', type=int, default=102)
    ab_parser.add_argument('--output', default='antibody.pdb')

    # origami
    orig_parser = sub.add_parser('origami', help='DNA origami design')
    orig_parser.add_argument('--shape', required=True, help='JSON with vertices and edges')
    orig_parser.add_argument('--output', default='origami', help='Base filename for PDB/oxDNA')
    orig_parser.add_argument('--bv_check', action='store_true')

    # test
    test_parser = sub.add_parser('test', help='Run gradient validation test')
    test_parser.add_argument('--full', action='store_true')

    args = parser.parse_args()

    if args.command == 'refine':
        if not HAS_BIOTITE: print("Install biotite"); sys.exit(1)
        data = load_structure(args.input, args.chain)
        coords, seq = data['coords'], data['sequence']
        print(f"Loaded {len(seq)} residues")
        device = 'cuda' if (args.device=='auto' and torch.cuda.is_available()) else args.device
        cfg = RefinementConfig(
            device=device, steps=args.steps, lr=args.lr,
            use_rg=not args.no_rg, use_ssc=not args.no_ssc,
            use_milstein=args.milstein,
            use_pme=args.pme, use_multigrid=args.multigrid,
            use_block_lr=args.block_lr
        )
        engine = RefinementEngine(cfg)
        logging.basicConfig(level=logging.INFO)
        logger = logging.getLogger("REAL_FOLD_ONE")
        result = engine.refine(coords, seq, ligand_files=args.ligand,
                               chain_boundaries=args.boundaries,
                               logger=logger, return_trajectory=args.trajectory)
        if args.full_atom and args.output:
            full_coords = torch.tensor(result['coords'])
            chi = torch.tensor(result['chi'])
            save_full_atom_pdb(full_coords, seq, args.output, chi)
        else:
            save_structure(result['coords'], seq, args.output)
        print(f"Final energy: {result['final_energy']:.4f} kcal/mol")
        print(f"SOC sigma: {result['sigma']:.3f}  temperature: {result['temperature']:.1f} K")
        if args.trajectory:
            np.save(args.output.replace('.pdb','_traj.npy'), result['trajectory'])

    elif args.command == 'train':
        trainer = Trainer()
        alpha, lambd = trainer.train(args.input, epochs=args.epochs, lr=args.lr,
                                     use_full_atom=args.full_atom)
        print(f"Training finished. alpha={alpha:.4f}, lambda={lambd:.4f}")
        if args.output:
            with open(args.output, 'w') as f:
                json.dump({'alpha': alpha, 'lambda': lambd}, f)
            print(f"Parameters saved to {args.output}")

    elif args.command == 'antibody':
        if not HAS_BIOTITE: print("biotite required"); sys.exit(1)
        ant = load_structure(args.antigen)
        ant_coords = torch.tensor(ant['coords'], dtype=torch.float32)
        ant_seq = ant['sequence']
        print(f"Antigen: {len(ant_seq)} residues")
        ab_coords = torch.randn(len(ant_seq), 3) * 10
        ab_seq = "A" * len(ant_seq)
        scorer = RosettaScorer()
        modeler = CDRLoopModeler(scorer)
        best = modeler.remodel_loop(ab_coords, ab_seq, args.cdr_start, args.cdr_end, n_steps=500, temp=1.0)
        save_structure(best.cpu().numpy(), ab_seq, args.output)
        print(f"Antibody saved to {args.output}")

    elif args.command == 'origami':
        with open(args.shape) as f:
            data = json.load(f)
        vertices = data['vertices']
        edges = data['edges']
        origami = WireframeOrigami(vertices, edges)
        path = origami.route_scaffold()
        staples = origami.design_staples(path)
        print(f"Scaffold path length: {len(path)}")
        print(f"Designed {len(staples)} staples")
        if args.bv_check:
            bv = DNAOrigamiBV(vertices, edges)
            print(f"BV topological consistency: {bv.verify_topological_consistency()}")
        # Export full‑atom PDB by default
        origami.export_full_atom_pdb(f"{args.output}.pdb")
        origami.export_oxDNA(args.output)

    elif args.command == 'test':
        # simple validation test
        seq = "AA"
        coords = torch.tensor([[0.0, 0.0, 0.0], [3.8, 0.0, 0.0]], dtype=torch.float32, requires_grad=True)
        cfg = RefinementConfig(steps=20, device='cpu', use_rg=False, use_amp=False)
        engine = RefinementEngine(cfg)
        result = engine.refine(coords, seq, steps=20)
        print(f"Final energy: {result['final_energy']:.4f}")
        rmsd = compute_rmsd(coords, torch.tensor(result['coords']))
        print(f"RMSD from initial: {rmsd:.4f} Å")
        diff = validate_gradients(engine, coords, seq)
        print(f"Gradient validation error: {diff:.6f}")
        if diff < 0.01:
            print("Gradient test PASSED")
        else:
            print("Gradient test FAILED")

if __name__ == "__main__":
    main()
