def build_protein_full_atoms(ca_coords: torch.Tensor, sequence: str,
                              chi_angles: Optional[torch.Tensor] = None) -> Tuple[torch.Tensor, List[str], torch.Tensor]:
    device = ca_coords.device
    L = len(sequence)
    atoms_backbone = reconstruct_backbone(ca_coords)   # now defined
    all_coords = []
    all_types = []
    all_res_ids = []
    for i in range(L):
        aa = sequence[i]
        if aa not in RESIDUE_IC:
            aa = 'G'
        N_i = atoms_backbone['N'][i]
        CA_i = atoms_backbone['CA'][i]
        C_i = atoms_backbone['C'][i]
        O_i = atoms_backbone['O'][i]
        res_coords = [N_i, CA_i, C_i, O_i]
        res_types = ['N', 'CA', 'C', 'O']
        ic_entries = RESIDUE_IC.get(aa, [])
        chi_offset = 0
        for idx, (name, atype, blen, ang, dih, ref) in enumerate(ic_entries):
            if not all(r < len(res_coords) for r in ref):
                continue
            a = res_coords[ref[0]]
            b = res_coords[ref[1]]
            c = res_coords[ref[2]]
            if chi_angles is not None and chi_offset < chi_angles.shape[1]:
                dih = dih + chi_angles[i, chi_offset]
                chi_offset += 1
            new_pos = place_atom_ic(a, b, c, blen, ang, dih)
            res_coords.append(new_pos)
            res_types.append(atype)
        for coord, atype in zip(res_coords, res_types):
            all_coords.append(coord)
            all_types.append(atype)
            all_res_ids.append(i)
    if not all_coords:
        return (torch.empty((0, 3), device=device),
                [],
                torch.empty(0, device=device, dtype=torch.long))
    return torch.stack(all_coords), all_types, torch.tensor(all_res_ids, device=device, dtype=torch.long)

