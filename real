class PME(nn.Module):
    def __init__(self, grid_spacing: float = 0.75, alpha: Optional[float] = None,
                 interpolation_order: int = 3):
        super().__init__()
        self.grid_spacing = grid_spacing
        self.alpha = alpha
        self.interpolation_order = interpolation_order
        self.box = None
        self.inv_box = None
        self.ngrid = None

    def _setup_grid(self, coords: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor, int]:
        minc = coords.min(dim=0).values - 5.0
        maxc = coords.max(dim=0).values + 5.0
        L = (maxc - minc).max()
        minc = (minc + maxc) / 2 - L / 2
        maxc = minc + L
        box_vectors = torch.eye(3, device=coords.device) * L
        self.box = box_vectors
        self.inv_box = torch.inverse(box_vectors)
        self.ngrid = max(16, int(L / self.grid_spacing))
        self.ngrid = self.ngrid + (self.ngrid % 2)
        return self.box, self.inv_box, self.ngrid

    def _spread(self, coords: torch.Tensor, q: torch.Tensor,
                inv_box: torch.Tensor, ngrid: int) -> torch.Tensor:
        frac = coords @ inv_box
        frac = frac - torch.floor(frac)
        n = ngrid
        ix = (frac * n).long().clamp(0, n - 1)
        wx = frac * n - ix.float()
        ix1 = (ix[:, 0] + 1) % n
        iy1 = (ix[:, 1] + 1) % n
        iz1 = (ix[:, 2] + 1) % n
        grid = torch.zeros((n, n, n), device=coords.device, dtype=coords.dtype)
        w000 = (1 - wx[:, 0]) * (1 - wx[:, 1]) * (1 - wx[:, 2])
        w100 = wx[:, 0] * (1 - wx[:, 1]) * (1 - wx[:, 2])
        w010 = (1 - wx[:, 0]) * wx[:, 1] * (1 - wx[:, 2])
        w001 = (1 - wx[:, 0]) * (1 - wx[:, 1]) * wx[:, 2]
        w110 = wx[:, 0] * wx[:, 1] * (1 - wx[:, 2])
        w101 = wx[:, 0] * (1 - wx[:, 1]) * wx[:, 2]
        w011 = (1 - wx[:, 0]) * wx[:, 1] * wx[:, 2]
        w111 = wx[:, 0] * wx[:, 1] * wx[:, 2]
        idx_flat = ix[:, 0] * (n * n) + ix[:, 1] * n + ix[:, 2]
        idx100 = ix1 * (n * n) + ix[:, 1] * n + ix[:, 2]
        idx010 = ix[:, 0] * (n * n) + iy1 * n + ix[:, 2]
        idx001 = ix[:, 0] * (n * n) + ix[:, 1] * n + iz1
        idx110 = ix1 * (n * n) + iy1 * n + ix[:, 2]
        idx101 = ix1 * (n * n) + ix[:, 1] * n + iz1
        idx011 = ix[:, 0] * (n * n) + iy1 * n + iz1
        idx111 = ix1 * (n * n) + iy1 * n + iz1
        grid_flat = grid.view(-1)
        grid_flat.scatter_add_(0, idx_flat, q * w000)
        grid_flat.scatter_add_(0, idx100, q * w100)
        grid_flat.scatter_add_(0, idx010, q * w010)
        grid_flat.scatter_add_(0, idx001, q * w001)
        grid_flat.scatter_add_(0, idx110, q * w110)
        grid_flat.scatter_add_(0, idx101, q * w101)
        grid_flat.scatter_add_(0, idx011, q * w011)
        grid_flat.scatter_add_(0, idx111, q * w111)
        return grid_flat.view(n, n, n)

    def _solve_recip(self, grid: torch.Tensor, box: torch.Tensor,
                     ngrid: int, alpha: float) -> torch.Tensor:
        kx = torch.fft.fftfreq(ngrid, d=box[0, 0].item() / ngrid, device=grid.device)
        ky = torch.fft.fftfreq(ngrid, d=box[1, 1].item() / ngrid, device=grid.device)
        kz = torch.fft.fftfreq(ngrid, d=box[2, 2].item() / ngrid, device=grid.device)
        KX, KY, KZ = torch.meshgrid(kx, ky, kz, indexing='ij')
        k2 = KX**2 + KY**2 + KZ**2
        k2[0, 0, 0] = 1.0
        B = torch.exp(-k2 / (4 * alpha**2)) / k2
        B[0, 0, 0] = 0.0
        Qk = torch.fft.fftn(grid)
        Ek = B * torch.abs(Qk)**2
        volume = box[0, 0] * box[1, 1] * box[2, 2]
        E = 0.5 * Ek.sum().real * (volume / ngrid**3)
        return E

    def energy(self, coords: torch.Tensor, q: torch.Tensor) -> torch.Tensor:
        if coords.shape[0] == 0:
            return torch.tensor(0.0, device=coords.device)
        box, inv_box, ngrid = self._setup_grid(coords)
        if self.alpha is None:
            self.alpha = 0.4 / self.grid_spacing
        alpha = self.alpha
        grid = self._spread(coords, q, inv_box, ngrid)
        E_recip = self._solve_recip(grid, box, ngrid, alpha)
        self_energy = -alpha / math.sqrt(math.pi) * (q**2).sum()
        return E_recip + self_energy

    def forces(self, coords: torch.Tensor, q: torch.Tensor) -> torch.Tensor:
        coords.requires_grad_(True)
        E = self.energy(coords, q)
        grad = torch.autograd.grad(E, coords, create_graph=True)[0]
        return -grad

