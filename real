def compute_rmsd(coords1, coords2):
    if isinstance(coords1, np.ndarray):
        coords1 = torch.from_numpy(coords1)
    if isinstance(coords2, np.ndarray):
        coords2 = torch.from_numpy(coords2)
    c1 = coords1 - coords1.mean(dim=0)
    c2 = coords2 - coords2.mean(dim=0)
    C = c1.T @ c2
    U, S, Vt = torch.linalg.svd(C)
    V = Vt.T
    det = torch.det(V @ U.T)
    if det < 0:
        V[:, -1] = -V[:, -1]
    R = V @ U.T
    rotated = c2 @ R.T
    diff = c1 - rotated
    rmsd = torch.sqrt((diff**2).sum() / coords1.shape[0])
    return rmsd.item()

def validate_gradients(engine, coords, sequence, eps=1e-4):
    coords = coords.clone().detach().requires_grad_(True)
    engine.cfg.use_amp = False
    E = engine._total_energy(coords, sequence, 
                             torch.ones(len(sequence)), 
                             torch.zeros(len(sequence),4),
                             engine._build_edges(coords),
                             torch.empty(2,0), torch.empty(0),
                             [], ['protein']*len(sequence), None)
    E.backward()
    anal_grad = coords.grad.clone()
    fd_grad = torch.zeros_like(coords)
    for i in range(coords.shape[0]):
        for j in range(3):
            orig = coords[i,j].item()
            coords[i,j] = orig + eps
            E_plus = engine._total_energy(coords, sequence, 
                                          torch.ones(len(sequence)), 
                                          torch.zeros(len(sequence),4),
                                          engine._build_edges(coords),
                                          torch.empty(2,0), torch.empty(0),
                                          [], ['protein']*len(sequence), None)
            coords[i,j] = orig - eps
            E_minus = engine._total_energy(coords, sequence, 
                                           torch.ones(len(sequence)), 
                                           torch.zeros(len(sequence),4),
                                           engine._build_edges(coords),
                                           torch.empty(2,0), torch.empty(0),
                                           [], ['protein']*len(sequence), None)
            fd_grad[i,j] = (E_plus - E_minus) / (2*eps)
            coords[i,j] = orig
    diff = torch.norm(anal_grad - fd_grad) / (torch.norm(anal_grad) + 1e-8)
    return diff.item()

