def build_single_nucleotide_ic(C4_prime, prev_C4, next_C4, nt_type):
    device = C4_prime.device
    topo = NUCLEOTIDE_TOPOLOGY.get(nt_type, [])
    if not topo: return torch.zeros((0,3), device=device), []
    coords, types = [], []
    if prev_C4 is not None and next_C4 is not None:
        x = _normalize(next_C4 - C4_prime)
        vtmp = C4_prime - prev_C4
        z = _normalize(torch.cross(x, vtmp, dim=-1))
        y = torch.cross(z, x, dim=-1)
    elif next_C4 is not None:
        x = _normalize(next_C4 - C4_prime)
        y = torch.tensor([0.,1.,0.], device=device)
        z = _normalize(torch.cross(x, y, dim=-1))
        y = torch.cross(z, x, dim=-1)
    else:
        x = torch.tensor([1.,0.,0.], device=device)
        y = torch.tensor([0.,1.,0.], device=device)
        z = torch.tensor([0.,0.,1.], device=device)
    for name, typ, parent, blen, ang, ref, dih0 in topo:
        if parent == 0 and len(coords)==0:
            pos = C4_prime
        elif parent < len(coords):
            ppos = coords[parent]
            a,b,c = ref
            def map_idx(idx, cur):
                if idx==0: return parent
                elif idx>0: return min(idx-1, cur-1) if cur>0 else 0
                else: return max(0, cur+idx)
            aa = map_idx(a, len(coords)); bb = map_idx(b, len(coords)); cc = map_idx(c, len(coords))
            pa = coords[aa] if aa<len(coords) else ppos
            pb = coords[bb] if bb<len(coords) else ppos
            pc = coords[cc] if cc<len(coords) else ppos
            bc = pc - pb; bcn = _normalize(bc)
            refv = torch.tensor([1.,0.,0.], device=device)
            if abs(torch.dot(bcn, refv)) > 0.9: refv = torch.tensor([0.,1.,0.], device=device)
            perp = torch.cross(bcn, refv, dim=-1)
            if perp.norm() < 1e-12:
                refv = torch.tensor([0.,0.,1.], device=device)
                perp = torch.cross(bcn, refv, dim=-1)
            perp = _normalize(perp)
            tot_ang = math.radians(dih0)
            ca_ang, sa = math.cos(tot_ang), math.sin(tot_ang)
            cp = torch.cross(bcn, perp, dim=-1)
            rp = perp * ca_ang + cp * sa
            ang_rad = math.radians(ang)
            dir_vec = math.cos(ang_rad)*bcn + math.sin(ang_rad)*rp
            pos = pc + blen * dir_vec
        else:
            pos = coords[-1] + blen * x if coords else C4_prime + blen * x
        coords.append(pos); types.append(name)
    return torch.stack(coords, dim=0), types

def build_full_dna_rna(C4_coords, sequence):
    L = len(sequence)
    device = C4_coords.device
    all_c, all_t, all_r = [], [], []
    for i in range(L):
        prev = C4_coords[i-1] if i>0 else None
        nxt = C4_coords[i+1] if i<L-1 else None
        nc, nt = build_single_nucleotide_ic(C4_coords[i], prev, nxt, sequence[i])
        all_c.append(nc); all_t.extend(nt)
        all_r.append(torch.full((nc.shape[0],), i, dtype=torch.long, device=device))
    if not all_c:
        return torch.zeros((0,3), device=device), [], torch.zeros(0, device=device)
    return torch.cat(all_c, dim=0), all_t, torch.cat(all_r, dim=0)

def build_dna_helix(seq, rise=3.38, twist=36.0, radius=8.0, start=0.0):
    L = len(seq)
    coords = torch.zeros(L,3)
    for i in range(L):
        ang = start + math.radians(i*twist)
        coords[i,0] = radius * math.cos(ang)
        coords[i,1] = radius * math.sin(ang)
        coords[i,2] = i*rise
    return coords

def energy_dna_rna_full(c4, seq, w_bp=8.0, w_stack=5.0, w_backbone=30.0,
                         w_lj=30.0, w_coulomb=3.0, cutoff=12.0, max_neighbors=64):
    all_c, all_t, res_idx = build_full_dna_rna(c4, seq)
    if all_c.shape[0] == 0: return torch.tensor(0.0, device=c4.device)
    L = len(seq)
    E = torch.tensor(0.0, device=c4.device)
    if L>1:
        d = torch.norm(c4[1:]-c4[:-1], dim=-1)
        E += w_backbone * ((d-6.5)**2).mean()
    for i in range(L):
        for j in range(i+4, min(L,i+50)):
            d = torch.norm(c4[i]-c4[j])
            n = WC_PAIRS.get((seq[i], seq[j]), 0)
            if n>0:
                E += -n * w_bp * torch.exp(-((d-10.5)/2.0)**2)
    for i in range(L-1):
        d = torch.norm(c4[i+1]-c4[i])
        s = 0.5 * (BASE_STACKING.get(seq[i],1.0) + BASE_STACKING.get(seq[i+1],1.0))
        E += -s * w_stack * torch.exp(-((d-6.5)/1.5)**2)
    # nonbonded for all atoms
    ei, ed = NeighborListManager({'lj':cutoff}, max_neighbors).build(all_c)['lj']
    if ei.numel() > 0:
        sig = torch.zeros(len(all_t), device=all_c.device)
        eps = torch.zeros(len(all_t), device=all_c.device)
        for k, t in enumerate(all_t):
            s, e = NUCLEOTIDE_LJ.get(t, (1.9,0.1))
            sig[k] = s; eps[k] = e
        src, dst = ei
        sig_ij = 0.5*(sig[src]+sig[dst])
        eps_ij = torch.sqrt(eps[src]*eps[dst])
        r = torch.clamp(ed, min=1e-4)
        inv_r = 1.0/r
        lj = 4.0*eps_ij * ((sig_ij*inv_r)**12 - (sig_ij*inv_r)**6)
        E += w_lj * lj.mean()
        q = torch.tensor([NUCLEOTIDE_CHARGES.get(t,0.0) for t in all_t], device=all_c.device)
        qi = q[src]; qj = q[dst]
        coul = 332.0637 * qi * qj / (4.0 * r)
        E += w_coulomb * coul.mean()
    return E

