# 8. Block-wise Multipole Long-Range Correction (Differentiable)
# =============================================================================

class MultipoleCorrection(nn.Module):
    def __init__(self, n_blocks: int = 8, max_l: int = 4):
        super().__init__()
        self.n_blocks = n_blocks
        self.max_l = max_l

    def _compute_multipole_moments(self, coords: torch.Tensor, charges: torch.Tensor,
                                    centers: torch.Tensor) -> List[torch.Tensor]:
        moments = []
        for l in range(self.max_l + 1):
            dr = coords - centers.unsqueeze(1)
            r = torch.norm(dr, dim=-1)
            if l == 0:
                moment = charges.sum(dim=-1)
            elif l == 1:
                moment = (charges.unsqueeze(-1) * dr).sum(dim=1)
            elif l == 2:
                moment = (charges.unsqueeze(-1).unsqueeze(-1) *
                          dr.unsqueeze(-1) * dr.unsqueeze(-2)).sum(dim=1)
            else:
                moment = torch.zeros_like(charges[0])
            moments.append(moment)
        return moments

    def energy(self, coords: torch.Tensor, charges: torch.Tensor) -> torch.Tensor:
        if coords.shape[0] < 2:
            return torch.tensor(0.0, device=coords.device)
        n_atoms = coords.shape[0]
        block_size = max(1, n_atoms // self.n_blocks)
        total_energy = torch.tensor(0.0, device=coords.device)
        for i in range(self.n_blocks):
            start_i = i * block_size
            end_i = min((i + 1) * block_size, n_atoms)
            for j in range(i + 1, self.n_blocks):
                start_j = j * block_size
                end_j = min((j + 1) * block_size, n_atoms)
                center_i = coords[start_i:end_i].mean(dim=0)
                center_j = coords[start_j:end_j].mean(dim=0)
                R = torch.norm(center_i - center_j)
                if R > 10.0:
                    q_i = charges[start_i:end_i].sum()
                    q_j = charges[start_j:end_j].sum()
                    energy = COULOMB_CONST * q_i * q_j / R
                    total_energy += energy
        return total_energy

